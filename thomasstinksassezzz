function getHarvestables(range, fruitName)
    local found = {}
    local seenEIDs = {}
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return found end

    local overlapParams = OverlapParams.new()
    overlapParams.FilterDescendantsInstances = {plr.Character}
    overlapParams.FilterType = Enum.RaycastFilterType.Exclude
    
    local parts = workspace:GetPartBoundsInRadius(hrp.Position, range or 30, overlapParams)

    for _, part in ipairs(parts) do
        if part and part.Parent and part.Parent:IsA("Model") then
            local model = part.Parent
            local eid = model:GetAttribute("EntityID")
            if eid and not seenEIDs[eid] then
                local isMatch = false
                for _, name in ipairs(validHarvestablesCache) do
                    if model.Name:find(name) then
                        isMatch = true
                        break
                    end
                end

                if isMatch then
                    local diff = model:GetPivot().Position - hrp.Position
                    local distSq = diff:Dot(diff)
                    local rangeSq = (range or 30) * (range or 30)
