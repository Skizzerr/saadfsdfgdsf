local dockPlaceGridActive = false
function startPlaceDocks()
    if dockPlaceGridActive then return end
    dockPlaceGridActive = true
    table.clear(pendingDockPlacements)
    
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local baseGridCFrame = CFrame.new(0,0,0, -0.551313877, 0, -0.834298372, 0, 1, 0, 0.834298372, 0, -0.551313877) * CFrame.Angles(0, math.rad(Settings.DockRotation or 0), 0)
        local Z_GAP = 32.0
        local X_GAP = 13.0
        local localPos = baseGridCFrame:PointToObjectSpace(hrp.Position)
        DockAnchor = {
            row = math.floor(localPos.Z / Z_GAP + 0.5),
            col = math.floor(localPos.X / X_GAP + 0.5)
        }
    end
    
    task.spawn(function()
        while Settings.PlaceDocks do
            local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then task.wait(0.02) continue end
            
            local now = tick()
            for key, time in pairs(pendingDockPlacements) do 
                if now - time > 0.5 then pendingDockPlacements[key] = nil end 
            end

            local baseGridCFrame = CFrame.new(0,0,0, -0.551313877, 0, -0.834298372, 0, 1, 0, 0.834298372, 0, -0.551313877) * CFrame.Angles(0, math.rad(Settings.DockRotation or 0), 0)
            local rx, ry, rz = baseGridCFrame:ToEulerAnglesXYZ()
            local Z_GAP = 32.0
            local X_GAP = 13.0
            
            local baseRow = DockAnchor and DockAnchor.row or math.floor(baseGridCFrame:PointToObjectSpace(hrp.Position).Z / Z_GAP + 0.5)
            local baseCol = DockAnchor and DockAnchor.col or math.floor(baseGridCFrame:PointToObjectSpace(hrp.Position).X / X_GAP + 0.5)

            local amount = Settings.DockAmount or 9
            local shape = Settings.DockShape or "Square"
            local offsets = {}

            if shape == "Rectangle" then
                -- Build outwards along the X-axis (horizontally) first instead of the Z-axis (vertically)
                local cols = math.max(1, math.ceil(math.sqrt(amount / 2)))
                local rows = math.ceil(amount / cols)
                local r0 = 0 
                local c0 = 0 
                local count = 0
                for c = 0, cols-1 do
                    for r = 0, rows-1 do
                        if count < amount then
                            table.insert(offsets, {r = r0 + r, c = c0 + c})
                            count = count + 1
                        end
                    end
                end
            else
                local side = math.max(1, math.ceil(math.sqrt(amount)))
                local r0 = 0 
                local c0 = 0 
                local count = 0
                for r = 0, side-1 do
                    for c = 0, side-1 do
                        if count < amount then
                            table.insert(offsets, {r = r0 + r, c = c0 + c})
                            count = count + 1
                        end
                    end
                end
            end

            local candidates = {}
            for _, off in ipairs(offsets) do
                local localTarget = Vector3.new((baseCol + off.c) * X_GAP, 0, (baseRow + off.r) * Z_GAP)
                local worldTarget = baseGridCFrame:PointToWorldSpace(localTarget)
                local targetX = worldTarget.X
                local targetZ = worldTarget.Z
                
                local checkCFrame = CFrame.new(Vector3.new(targetX, hrp.Position.Y, targetZ)) * baseGridCFrame.Rotation
                local checkSize = Vector3.new(4, 100, 4) 
                local parts = workspace:GetPartBoundsInBox(checkCFrame, checkSize)
                local occupied = false
                
                for _, p in ipairs(parts) do 
                    local model = p:FindFirstAncestorOfClass("Model")
                    if model and model.Name == "Dock" then
                        local pPos = model:GetPivot().Position
                        local distToCenter = math.sqrt((pPos.X - targetX)^2 + (pPos.Z - targetZ)^2)
                        if distToCenter < 2.0 then
                            occupied = true 
                            break 
                        end
                    end 
                end
                
                if not occupied then
                    local key = string.format("%.1f,%.1f", targetX, targetZ)
                    if not pendingDockPlacements[key] then
                        table.insert(candidates, {x = targetX, z = targetZ, key = key, r = off.r, c = off.c})
                    end
                end
            end
            
            table.sort(candidates, function(a, b) 
                -- Sort by the exact logical grid columns and rows!
                -- This forces it to completely finish a vertical column before moving horizontally,
                -- and perfectly ignores any world rotation that was causing zig-zagging.
                if a.c ~= b.c then
                    return a.c < b.c
                end
                return a.r < b.r
            end)
            
            if #candidates > 0 then
                local cand = candidates[1]
                local rayOrigin = Vector3.new(cand.x, hrp.Position.Y + 30, cand.z)
                local rayDir = Vector3.new(0, -500, 0)
                local rayParams = RaycastParams.new()
                
                local ignoreList = {plr.Character}
                if PreviewContainer then table.insert(ignoreList, PreviewContainer) end
                if DockPreviewContainer then table.insert(ignoreList, DockPreviewContainer) end
                local ignoreFolders = {"Resources", "Rubble", "Critters", "Items", "Players", "MeteorParts"}
                for _, name in ipairs(ignoreFolders) do
                    local f = workspace:FindFirstChild(name)
                    if f then table.insert(ignoreList, f) end
                end
                
                rayParams.FilterDescendantsInstances = ignoreList
                rayParams.FilterType = Enum.RaycastFilterType.Exclude
                rayParams.IgnoreWater = false
                
                local hit = workspace:Raycast(rayOrigin, rayDir, rayParams)
                if hit then
                    local targetY = hit.Position.Y
                    local pos = Vector3.new(cand.x, targetY, cand.z)
                    
                    local tweenTarget = CFrame.new(pos.X, pos.Y + 6, pos.Z)
                    local dist = (hrp.Position - tweenTarget.Position).Magnitude
                    local speed = Settings.DockTweenSpeed or 30
                    local timeToTween = dist / speed
                    if timeToTween < 0.1 then timeToTween = 0.1 end
                    
                    -- Fire placement BEFORE the tween so the dock exists when we arrive!
                    local name = "Dock"
                    if ByteNetReliable then
                        local nameLen = #name
                        local b = buffer.create(4 + nameLen + 24)
                        buffer.writeu8(b, 0, 0)
                        buffer.writeu8(b, 1, packetData().packets.PlaceStructure)
                        buffer.writeu16(b, 2, nameLen)
                        for i = 1, nameLen do buffer.writeu8(b, 3 + i, string.byte(name, i)) end
                        
                        local offset = 4 + nameLen
                        buffer.writef32(b, offset, pos.X)
                        buffer.writef32(b, offset + 4, pos.Y)
                        buffer.writef32(b, offset + 8, pos.Z)
                        
                        buffer.writef32(b, offset + 12, rx) -- RotX
                        buffer.writef32(b, offset + 16, ry) -- RotY
                        buffer.writef32(b, offset + 20, rz) -- RotZ
                        
                        ByteNetReliable:FireServer(b)
                        pendingDockPlacements[cand.key] = tick()
                        
                        if Settings.ShowDockPreview and DockPreviewCache[cand.key] then
                            DockPreviewCache[cand.key]:Destroy()
                            DockPreviewCache[cand.key] = nil
                        end
                    end
                    
                    local tween = game:GetService("TweenService"):Create(hrp, TweenInfo.new(timeToTween, Enum.EasingStyle.Linear), {CFrame = tweenTarget})
                    tween:Play()
                    tween.Completed:Wait()
                    task.wait(0.1)
                end
            else
                if DockAnchor then
                    Settings.PlaceDocks = false
                    DockAnchor = nil
                end
                task.wait(0.5)
            end
        end
        dockPlaceGridActive = false
        DockAnchor = nil
    end)
end
end

