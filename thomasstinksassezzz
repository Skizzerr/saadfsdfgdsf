    local function createDynamicThumbstick()
        if dynamicThumbstickGui then return end

        dynamicThumbstickGui = Instance.new("ScreenGui")
        dynamicThumbstickGui.Name = "FreeCamDynamicThumbstick"
        dynamicThumbstickGui.Parent = game:GetService("CoreGui")

        local thumbstickFrame, thumbstick
        local touchInput, touchStart
        local moveVector = Vector3.new()
        local verticalMove = 0



        thumbstickBeganConn = UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
            if gameProcessedEvent or input.UserInputType ~= Enum.UserInputType.Touch or touchInput then return end
            if input.Position.X > workspace.CurrentCamera.ViewportSize.X / 2 then return end

            touchInput = input
            touchStart = input.Position

            thumbstickFrame = Instance.new("Frame")
            thumbstickFrame.Size = UDim2.new(0, 150, 0, 150)
            thumbstickFrame.Position = UDim2.new(0, touchStart.X, 0, touchStart.Y)
            thumbstickFrame.AnchorPoint = Vector2.new(0.5, 0.5)
            thumbstickFrame.BackgroundTransparency = 0.5
            thumbstickFrame.BackgroundColor3 = Color3.new(0, 0, 0)
            thumbstickFrame.Parent = dynamicThumbstickGui

            local corner = Instance.new("UICorner")
            corner.CornerRadius = UDim.new(0.5, 0)
            corner.Parent = thumbstickFrame

            thumbstick = Instance.new("Frame")
            thumbstick.Size = UDim2.new(0, 50, 0, 50)
            thumbstick.Position = UDim2.new(0.5, 0, 0.5, 0)
            thumbstick.AnchorPoint = Vector2.new(0.5, 0.5)
            thumbstick.BackgroundColor3 = Color3.new(1, 1, 1)
            thumbstick.Parent = thumbstickFrame

            local thumbstickCorner = Instance.new("UICorner")
            thumbstickCorner.CornerRadius = UDim.new(0.5, 0)
            thumbstickCorner.Parent = thumbstick
        end)

        thumbstickChangedConn = UserInputService.InputChanged:Connect(function(input)
            if input == touchInput then
                local delta = input.Position - touchStart
                local radius = thumbstickFrame.AbsoluteSize.X / 2

                if delta.Magnitude > radius then
                    delta = delta.Unit * radius
                end

                thumbstick.Position = UDim2.new(0.5, delta.X, 0.5, delta.Y)
                moveVector = Vector3.new(delta.X / radius, 0, delta.Y / radius)
            end
        end)

        thumbstickEndedConn = UserInputService.InputEnded:Connect(function(input)
            if input == touchInput then
                touchInput = nil
                thumbstickFrame:Destroy()
                moveVector = Vector3.new()
            end
        end)

        local camera = workspace.CurrentCamera
        thumbstickRenderConn = game:GetService("RunService").RenderStepped:Connect(function(dt)
            if not Settings.FreeCamPhone then return end
            local moveSpeed = (Settings.FreeCamSpeed or 5)
            local finalMove = (camera.CFrame.RightVector * moveVector.X + camera.CFrame.LookVector * -moveVector.Z) * moveSpeed * dt
            camera.CFrame = CFrame.new(camera.CFrame.Position + finalMove) * camera.CFrame.Rotation
        end)
    end



