    function TabObj:AddSlider(text, min, max, default, arg5, arg6)
        local step = 0.01
        local callback
        if type(arg5) == "number" then
            step = arg5
            callback = arg6
        else
            callback = arg5
        end
        local decimals = 0
        local s = tostring(step)
        local dot = string.find(s, ".", 1, true)
        if dot then
            decimals = #s - dot
        end
        local parentColumn, order = getElementContainer()
        local sFrame = Instance.new("Frame", parentColumn); sFrame.Size = UDim2.new(1, 0, 0, 60); sFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25); Instance.new("UICorner", sFrame)
