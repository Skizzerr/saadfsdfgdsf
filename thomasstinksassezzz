-- SwingTool: u8 0, u8 actionId, u16 LE hitCount, hitCount*u32 ids, 19-byte cframe, f64.
function fireByteNetSwingTool(targetEntries, hrp, opts)
    opts = opts or {}
    if not targetEntries or #targetEntries == 0 or not ByteNetReliable or not hrp then return end

    local clean = {}
    for _, t in ipairs(targetEntries) do
        local id = math.floor(tonumber(t and t.eid) or 0)
        if id > 0 then
            table.insert(clean, { eid = id, pos = t.pos })
        end
    end
    if #clean == 0 then return end
    targetEntries = clean

    local okPd, pd = pcall(packetData)
    local swingId = 19
    if okPd and pd and pd.packets and type(pd.packets.SwingTool) == "number" then
        swingId = pd.packets.SwingTool
    end

    local function computeFromPos()
        local fromPos = hrp.Position
        if opts.fromPos then
            fromPos = opts.fromPos
        end
        if not opts.skipLead then
            local vel = hrp.AssemblyLinearVelocity or Vector3.zero
            local horizontalVel = Vector3.new(vel.X, 0, vel.Z)
            local tweening = opts.tweening
            if tweening == nil then
                tweening = (isTweening == true) or (horizontalVel.Magnitude > 18)
            end
            local leadTime = tweening and (opts.leadTime ~= nil and opts.leadTime or 0.12) or (opts.leadTime or 0)
            fromPos = fromPos + (horizontalVel * leadTime)
        end
        return fromPos
    end

    local function cframeForBatch(batch, fromPos)
        if #batch == 1 then
            local tp = batch[1].pos
            if typeof(tp) == "Vector3" and (tp - fromPos).Magnitude > 0.01 then
                return CFrame.lookAt(fromPos, tp)
            end
            return hrp.CFrame
        end
        local sum = Vector3.zero
        local n = 0
        for _, t in ipairs(batch) do
            if typeof(t.pos) == "Vector3" then
                sum = sum + t.pos
                n = n + 1
            end
        end
        if n > 0 then
            local center = sum / n
            if (center - fromPos).Magnitude > 0.01 then
                return CFrame.lookAt(fromPos, center)
            end
        end
        return hrp.CFrame
    end

    local maxPerPacket = math.clamp(opts.maxPerPacket or 32, 1, 64)
    local timeStep = opts.timeStep or 0.01
    local baseTime = opts.baseTime or (time() - timeStep)
    local run = game:GetService("RunService")
    local pktIdx = 0

    for startIdx = 1, #targetEntries, maxPerPacket do
        if pktIdx > 0 then
            run.Heartbeat:Wait()
        end
        pktIdx = pktIdx + 1

        local batch = {}
        for i = startIdx, math.min(startIdx + maxPerPacket - 1, #targetEntries) do
            table.insert(batch, targetEntries[i])
        end
        local n = #batch
        local fromPos = computeFromPos()
        local cfOff = 4 + 4 * n
        local tOff = cfOff + 19
        local b = buffer.create(4 + 4 * n + 19 + 8)
        buffer.writeu8(b, 0, 0)
        buffer.writeu8(b, 1, swingId)
        buffer.writeu16(b, 2, n)
        for i, t in ipairs(batch) do
            buffer.writeu32(b, 4 + (i - 1) * 4, math.floor(tonumber(t.eid) or 0))
        end
        writeByteNetCFrame(b, cfOff, cframeForBatch(batch, fromPos))
        buffer.writef64(b, tOff, baseTime + (pktIdx * timeStep))
        ByteNetReliable:FireServer(b)
    end
end

-- Alternate SwingTool wire (one packet, many ids): [0][actionId][u8 hitCount][0] then (u32 LE id, u8 0) per hit, then 26-byte trailer.
function fireByteNetSwingToolPackedMultiHit(targetEntries, hrp, opts)
    opts = opts or {}
    if not targetEntries or #targetEntries == 0 or not ByteNetReliable or not hrp then return end

    local seen = {}
    local clean = {}
    for _, t in ipairs(targetEntries) do
        local id = math.floor(tonumber(t and t.eid) or 0)
        if id > 0 and not seen[id] then
            seen[id] = true
            table.insert(clean, { eid = id })
        end
    end
    if #clean == 0 then return end

    local maxN = math.clamp(opts.maxTargets or 9, 1, 9)
    local n = math.min(#clean, maxN)

    local okPd, pd = pcall(packetData)
    local swingId = 19
    if okPd and pd and pd.packets and type(pd.packets.SwingTool) == "number" then
        swingId = pd.packets.SwingTool
    end

    local trailer = {
        0x7D, 0x06, 0xAA, 0xC3, 0x02, 0x00, 0x40, 0xC0,
        0x2F, 0x60, 0x8B, 0x42, 0x48, 0xC2, 0x33, 0xB6,
        0x48, 0xC2, 0x4E, 0x64, 0x6B, 0x3C, 0xA6, 0x7C, 0xDA, 0x41,
    }

    local b = buffer.create(4 + 5 * n + #trailer)
    buffer.writeu8(b, 0, 0)
    buffer.writeu8(b, 1, swingId)
    buffer.writeu8(b, 2, n)
    buffer.writeu8(b, 3, 0)
    local o = 4
    for i = 1, n do
        buffer.writeu32(b, o, clean[i].eid)
        buffer.writeu8(b, o + 4, 0)
        o = o + 5
    end
    for i, v in ipairs(trailer) do
        buffer.writeu8(b, o + i - 1, v)
    end
    ByteNetReliable:FireServer(b)
end

function getlayout(name)
    if not name or name == "" then return nil end
    local mainGui = plr.PlayerGui:FindFirstChild("MainGui")
    if not mainGui then return nil end
    local right = mainGui:FindFirstChild("RightPanel")
    local inv = right and right:FindFirstChild("Inventory")
    local list = inv and inv:FindFirstChild("List")
    if not list then return nil end
    local lowerTarget = string.lower((tostring(name):match("^%s*(.-)%s*$") or ""))
    if lowerTarget == "" then return nil end
    for _, child in ipairs(list:GetChildren()) do
        if child:IsA("GuiObject") then
            local cn = string.lower((tostring(child.Name):match("^%s*(.-)%s*$") or ""))
            if cn == lowerTarget then
                return child.LayoutOrder
            end
        end
    end
    return nil
end

function drop(itemName)
    local mainGui = game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("MainGui")
    local inventory = mainGui and mainGui.RightPanel and mainGui.RightPanel.Inventory and mainGui.RightPanel.Inventory.List
    local slotID = nil
    if inventory then
        -- Use case-insensitive exact match like dynamicDrop for better reliability
        local lowerTarget = itemName:lower():match("^%s*(.-)%s*$")
        if lowerTarget and lowerTarget ~= "" then
            for _, child in ipairs(inventory:GetChildren()) do
                if child:IsA("GuiObject") then
                    local childNameLower = child.Name:lower():match("^%s*(.-)%s*$")
                    if childNameLower == lowerTarget then
                        slotID = child.LayoutOrder
                        break
                    end
                end
            end
        end
    end

    if slotID and ByteNetReliable then
        local dropPacketId = getPacketId("DropBagItem")
        if not dropPacketId then return end
        local b = buffer.create(4)
        buffer.writeu8(b, 0, 0)
        buffer.writeu8(b, 1, dropPacketId)
        buffer.writeu16(b, 2, slotID) -- server expects LayoutOrder slot
        ByteNetReliable:FireServer(b)
    end
end

