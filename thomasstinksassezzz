local function getPreviewModel()
    local rs = game:GetService("ReplicatedStorage")
    local template = nil
    
    local quickFolders = {"Deployables", "PlaceStructures", "Structures", "Models"}
    for _, fname in ipairs(quickFolders) do
        local folder = rs:FindFirstChild(fname)
        if folder and folder:FindFirstChild("Plant Box") then
            template = folder:FindFirstChild("Plant Box")
            break
        end
    end
    
    if not template then
        for _, v in ipairs(rs:GetDescendants()) do
            if (v:IsA("Model") or v:IsA("BasePart")) and v.Name == "Plant Box" then
                template = v
                break
            end
        end
    end

    local model
    if template then
        model = template:Clone()
    else
        -- Fallback to simple part if model is missing (should rarely happen)
        model = Instance.new("Part")
        model.Size = Vector3.new(4, 1, 4)
        model.Color = Color3.fromRGB(0, 255, 100)
        model.CastShadow = false
    end
    
    model.Name = "PreviewBox"
    
    -- Recursive function to setup visual properties for all parts in the model
    local function setupVisuals(obj)
        if obj:IsA("BasePart") then
            obj.Transparency = 0.65
            obj.CanCollide = false
            obj.CastShadow = false
            -- Disable physics/raycast interactions
            pcall(function() obj.CanQuery = false obj.CanTouch = false end)
        end
        for _, child in ipairs(obj:GetChildren()) do
            setupVisuals(child)
        end
    end
    
    setupVisuals(model)
    
    -- Optimization for BulkMoveTo:
    -- We want to move only the PrimaryPart (Anchored) and have children (Unanchored + Welded) follow.
    if model:IsA("Model") then
        if not model.PrimaryPart then
            model.PrimaryPart = model:FindFirstChildWhichIsA("BasePart", true)
        end
        
        local pp = model.PrimaryPart
        if pp then
            pp.Anchored = true
            for _, desc in ipairs(model:GetDescendants()) do
                if desc:IsA("BasePart") and desc ~= pp then
                    desc.Anchored = false
                    local w = Instance.new("WeldConstraint")
                    w.Part0 = pp
                    w.Part1 = desc
                    w.Parent = pp
                end
            end
        end
    elseif model:IsA("BasePart") then
        model.Anchored = true
    end
    
    return model
end

local GroundHeightCache = {}
local OccupancyCache = {}
local CachedRayParams = nil
local LastParamsUpdate = 0

local function updatePreview()
    -- Strict check: Only show if the toggle is actually enabled
    if not Settings.ShowPlantBoxPreview then
        PreviewContainer:ClearAllChildren()
        table.clear(PreviewCache)
        table.clear(GroundHeightCache)
        table.clear(OccupancyCache)
        return
    end
    
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local currentTime = tick()

    -- [[ OPTIMIZATION: Persistent RaycastParams ]]
    -- Update params only once every 2 seconds or if missing
    if not CachedRayParams or (currentTime - LastParamsUpdate > 2.0) then
        local rayParams = RaycastParams.new()
        local ignoreList = {}
        if plr.Character then table.insert(ignoreList, plr.Character) end
        if PreviewContainer then table.insert(ignoreList, PreviewContainer) end
        if DockPreviewContainer then table.insert(ignoreList, DockPreviewContainer) end
        
        local ignoreFolders = {"Resources", "Rubble", "Critters", "Items", "Players", "MeteorParts"}
        for _, name in ipairs(ignoreFolders) do
            local f = workspace:FindFirstChild(name)
            if f then table.insert(ignoreList, f) end
        end
        rayParams.FilterDescendantsInstances = ignoreList
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.IgnoreWater = true
        
        CachedRayParams = rayParams
        LastParamsUpdate = currentTime
    end
    
    -- Grid Constants
    local Z_GAP = 5.24
    local X_GAP = 6.05
    local OFFSET = 3.025
    
    -- Determine Center
    local centerPos = hrp.Position
    
    local baseRow = math.floor(centerPos.Z / Z_GAP + 0.5)
    local baseCol = math.floor(centerPos.X / X_GAP + 0.5)
    
    -- Determine Radius based on Mode
    local RADIUS = 6
    if Settings.PlantMode == "SinglePlantBoxPlacement" then
        RADIUS = 0 -- Single Box Mode
    end
    
    local activeKeys = {}
    local partsToMove = {}
    local cframesToMove = {}
    
    for r = baseRow - RADIUS, baseRow + RADIUS do
        for c = baseCol - RADIUS, baseCol + RADIUS do
            local rowDiff = r 
            local currentOffset = (math.abs(rowDiff) % 2 == 1) and OFFSET or 0
            local targetX = (c * X_GAP) + currentOffset
            local targetZ = (r * Z_GAP)
            local key = string.format("%.1f,%.1f", targetX, targetZ)
            
            -- Check validity based on mode
            local isValid = false
            
            if RADIUS == 0 then
                -- Strict Single Box
                isValid = (r == baseRow and c == baseCol)
            else
                -- Multi Box: Square Grid
                isValid = true
            end
            
            if isValid then
                activeKeys[key] = true
                
                -- [[ Terrain Adaptation with Caching ]]
                local cellY = hrp.Position.Y - 3 -- Default fallback
                local cached = GroundHeightCache[key]
                
                -- Re-check height every 3 seconds
                if cached and (currentTime - cached.t < 3.0) then
                    cellY = cached.y
                else
                    local rayOrigin = Vector3.new(targetX, hrp.Position.Y + 30, targetZ)
                    local rayDir = Vector3.new(0, -100, 0)
                    local hit = workspace:Raycast(rayOrigin, rayDir, CachedRayParams)
                    
                    if hit then
                        cellY = hit.Position.Y
                        GroundHeightCache[key] = {y = cellY, t = currentTime}
                    else
                        GroundHeightCache[key] = {y = cellY, t = currentTime}
                    end
                end
                
                -- [[ Occupancy Check with Caching ]]
                -- GetPartBoundsInBox is expensive, so we cache the result for 0.25 seconds.
                -- This reduces physics queries by ~15x.
                local occupied = false
                local occCached = OccupancyCache[key]
                
                if occCached and (currentTime - occCached.t < 0.25) then
                    occupied = occCached.val
                else
                    local checkCFrame = CFrame.new(targetX, cellY + 5, targetZ)
                    local checkSize = Vector3.new(4, 10, 4) 
                    local parts = workspace:GetPartBoundsInBox(checkCFrame, checkSize)
                    
                    for _, p in ipairs(parts) do 
                        local model = p:FindFirstAncestorOfClass("Model")
                        if model and model.Name == "Plant Box" then
                             local pPos = model:GetPivot().Position
                             local distToCenter = math.sqrt((pPos.X - targetX)^2 + (pPos.Z - targetZ)^2)
                             if distToCenter < 2.0 then
                                occupied = true 
                                break 
                             end
                        end 
                    end
                    OccupancyCache[key] = {val = occupied, t = currentTime}
                end
                
                if not occupied and not pendingPlacements[key] then
                    -- Show Preview
                    local model = PreviewCache[key]
                    if not model then
                        model = getPreviewModel()
                        model.Parent = PreviewContainer
                        PreviewCache[key] = model
                    end
                    
                    local pp = model.PrimaryPart or (model:IsA("BasePart") and model)
                    if pp then
                        table.insert(partsToMove, pp)
                        local heightOffset = pp.Size.Y / 2
                        table.insert(cframesToMove, CFrame.new(targetX, cellY + heightOffset, targetZ))
                    end
                else
                    -- Remove if occupied or pending
                    if PreviewCache[key] then
                        PreviewCache[key]:Destroy()
                        PreviewCache[key] = nil
                    end
                end
            end
        end
    end
    
    -- Cleanup inactive previews and cache
    for key, model in pairs(PreviewCache) do
        if not activeKeys[key] then
            model:Destroy()
            PreviewCache[key] = nil
            if GroundHeightCache[key] then GroundHeightCache[key] = nil end
            if OccupancyCache[key] then OccupancyCache[key] = nil end
        end
    end
    
    -- [[ BulkMoveTo Optimization ]] --
    if #partsToMove > 0 then
        workspace:BulkMoveTo(partsToMove, cframesToMove)
    end
end

