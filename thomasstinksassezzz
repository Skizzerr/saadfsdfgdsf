        if v then
            -- If locking is enabled and we don't have a saved position, try to auto-lock nearest
            if not Settings.SavedChestPosition and not ASTER.ConfigSystem.Loading then
                local chests = {}
                -- Helper function to find chests since getBigChests might be nil or undefined here
                local function findChests()
                    local c = {}
                    local d = workspace:FindFirstChild("Deployables")
                    if d then
                        for _, obj in ipairs(d:GetChildren()) do
                            if (obj.Name:find("Chest") or obj.Name:find("Box")) and not obj.Name:find("Plant Box") then
                                table.insert(c, obj)
                            end
                        end
                    end
                    return c
                end
                
                chests = findChests()
                local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local closest, dist = nil, math.huge
                    for _, c in ipairs(chests) do
                        local d = (c:GetPivot().Position - hrp.Position).Magnitude
                        if d < dist then dist = d closest = c end
                    end
                    if closest and dist < 60 then
                        Settings.SavedChestPosition = closest:GetPivot().Position
                        if ASTER.Options.SavedChestX then ASTER.Options.SavedChestX:SetValue(tostring(Settings.SavedChestPosition.X)) end
                        if ASTER.Options.SavedChestY then ASTER.Options.SavedChestY:SetValue(tostring(Settings.SavedChestPosition.Y)) end
                        if ASTER.Options.SavedChestZ then ASTER.Options.SavedChestZ:SetValue(tostring(Settings.SavedChestPosition.Z)) end
                    end
                end
            end
        else
            -- Unlock: Clear saved position ONLY if user clicked (not loading)
            if not ASTER.ConfigSystem.Loading then
                Settings.SavedChestPosition = nil
                if ASTER.Options.SavedChestX then ASTER.Options.SavedChestX:SetValue("0") end
                if ASTER.Options.SavedChestY then ASTER.Options.SavedChestY:SetValue("0") end
