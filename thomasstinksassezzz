                 if targetNames[name] then
                     godItems[id] = name
                 end
             end
        end
        
        if not next(godItems) then
            godItems = {
                [16] = "God Halo",
                [26] = "God Chestplate",
                [288] = "God Legs"
            }
        end
        local godNames = {
