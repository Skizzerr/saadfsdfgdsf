    local previewParts = {}
    local previewConnection = nil
    
    local function updatePreviewModels()
        -- Clear old preview models
        for _, p in ipairs(previewParts) do 
            if p then p:Destroy() end
        end
        table.clear(previewParts)
        
        local itemName = ConfigPinch.ItemName or "Crystal Gate"
        local modelTemplate = nil
        local rs = game:GetService("ReplicatedStorage")
        
        -- 1. Fast check common Booga Booga Reborn folders
        local quickFolders = {"Deployables", "PlaceStructures", "Structures", "Models"}
        for _, fname in ipairs(quickFolders) do
            local folder = rs:FindFirstChild(fname)
            if folder and folder:FindFirstChild(itemName) then
                modelTemplate = folder:FindFirstChild(itemName)
                break
            end
        end
        
        -- 2. Deep search ReplicatedStorage if not found in common folders
        if not modelTemplate then
            for _, v in ipairs(rs:GetDescendants()) do
                if (v:IsA("Model") or v:IsA("BasePart")) and v.Name == itemName then
                    modelTemplate = v
                    break
                end
            end
        end
        
        for i = 1, 2 do
            local previewObj
            if modelTemplate then
                previewObj = modelTemplate:Clone()
                
                -- Make translucent and uncollidable
                if previewObj:IsA("BasePart") then
                    previewObj.CanCollide = false
                    previewObj.Anchored = true
                    previewObj.Transparency = 0.5
                    previewObj.Material = Enum.Material.ForceField
                    previewObj.Color = Color3.new(0, 1, 0)
                end
                
                for _, desc in ipairs(previewObj:GetDescendants()) do
                    if desc:IsA("BasePart") then
                        desc.CanCollide = false
                        desc.Anchored = true
                        desc.Transparency = 0.5
                        desc.Material = Enum.Material.ForceField
                        desc.Color = Color3.new(0, 1, 0)
                    end
                end
                
                -- Ensure PrimaryPart exists for moving the model
                if previewObj:IsA("Model") and not previewObj.PrimaryPart then
                    local firstPart = previewObj:FindFirstChildWhichIsA("BasePart", true)
                    if firstPart then
                        previewObj.PrimaryPart = firstPart
                    else
                        -- Fallback if no parts exist in model
                        previewObj:Destroy()
                        previewObj = nil
                    end
                end
            end
            
            -- Fallback to simple part if model not found
            if not previewObj then
                previewObj = Instance.new("Part")
                previewObj.Name = "PinchPreviewFallbackPart" .. i
                previewObj.Size = Vector3.new(4, 8, 1)
                previewObj.Anchored = true
                previewObj.CanCollide = false
                previewObj.Material = Enum.Material.ForceField
                previewObj.Color = Color3.new(0, 1, 0)
                previewObj.Transparency = 0.3
            else
                previewObj.Name = "PinchPreviewPart" .. i
            end
            
            previewObj.Parent = workspace
            previewParts[i] = previewObj
        end
    end
    
    ASTER.Tabs.Combat:AddToggle("Preview Pinch Placements", false, function(v)
        if v then
            updatePreviewModels()
            
            previewConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if ConfigPinch.TargetPlayer and ConfigPinch.TargetPlayer.Character then
                    local char = ConfigPinch.TargetPlayer.Character
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local targetBase = hrp.Position
                        local velocity = hrp.AssemblyLinearVelocity
                        local horizontalVelocity = Vector3.new(velocity.X, 0, velocity.Z)
                        if horizontalVelocity.Magnitude > 2 then
                            targetBase = targetBase + (horizontalVelocity.Unit * 5)
                        end
                        
                        local rot = CFrame.Angles(0, math.rad(ConfigPinch.FixedRotation), 0) 
                        local xOff = ConfigPinch.X_Offset or 0
                        local zOff = ConfigPinch.Z_Offset or 0
                        
                        local cf1 = CFrame.new(targetBase.X + xOff, targetBase.Y - 3.5, targetBase.Z + zOff) * rot 
                        local cf2 = CFrame.new(targetBase.X - xOff, targetBase.Y - 3.5, targetBase.Z - zOff) * rot 
                        
                        -- Set CFrame based on object type
                        for i, cframe in ipairs({cf1, cf2}) do
                            local obj = previewParts[i]
                            if obj then
                                if obj:IsA("Model") then
                                    -- The visual model's PrimaryPart often has its own internal rotation offset
                                    -- We need to rotate the preview model by 90 degrees on the Y axis to match the actual placement
                                    obj:SetPrimaryPartCFrame(cframe * CFrame.Angles(0, math.rad(90), 0))
                                elseif obj.Name:match("FallbackPart") then
                                    -- This is the fallback simple part, offset by 4
                                    obj.CFrame = cframe * CFrame.new(0, 4, 0)
                                else
                                    -- This is an actual BasePart model from the game
                                    obj.CFrame = cframe
                                end
                            end
                        end
                    end
                else
                    -- Hide preview if no target is selected
                    for i = 1, 2 do
                        local obj = previewParts[i]
                        if obj then
                            if obj:IsA("Model") then
                                obj:SetPrimaryPartCFrame(CFrame.new(0, -1000, 0))
                            else
                                obj.CFrame = CFrame.new(0, -1000, 0)
                            end
                        end
                    end
                end
            end)
        else
            if previewConnection then 
                previewConnection:Disconnect() 
                previewConnection = nil
            end
            for _, p in ipairs(previewParts) do 
                if p then p:Destroy() end
            end
            table.clear(previewParts)
        end
    end)

