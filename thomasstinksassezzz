        local label = Instance.new("TextLabel", sFrame); label.Text = "  " .. text; label.Size = UDim2.new(1, 0, 0.5, 0); label.Font = "SourceSansBold"; label.TextSize = 16; label.TextColor3 = Color3.new(1,1,1); label.TextXAlignment = "Left"; label.BackgroundTransparency = 1
        ApplyGradient(label); table.insert(Window.TextElements, label)
        local val = Instance.new("TextLabel", sFrame); val.Text = ""; val.Size = UDim2.new(1, 0, 0.5, 0); val.Font = "SourceSansBold"; val.TextSize = 16; val.TextColor3 = Color3.new(1,1,1); val.TextXAlignment = "Right"; val.BackgroundTransparency = 1
        ApplyGradient(val); table.insert(Window.TextElements, val)
        local barBg = Instance.new("Frame", sFrame); barBg.Size = UDim2.new(1, -20, 0, 6); barBg.Position = UDim2.new(0, 10, 0.75, 0); barBg.BackgroundColor3 = Color3.fromRGB(45, 45, 45); Instance.new("UICorner", barBg)
        local fill = Instance.new("Frame", barBg); fill.BackgroundColor3 = Color3.new(1,1,1); Instance.new("UICorner", fill); ApplyGradient(fill); table.insert(Window.ThemedElements, fill)
        local grab = Instance.new("Frame", fill) 
        grab.AnchorPoint = Vector2.new(0.5, 0.5); grab.Position = UDim2.new(1, 0, 0.5, 0); grab.Size = UDim2.fromOffset(14, 14); grab.BackgroundColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", grab).CornerRadius = UDim.new(1, 0); ApplyGradient(grab); table.insert(Window.ThemedElements, grab)
        local currentVal = default or min
        if currentVal < min then
            currentVal = min
        elseif currentVal > max then
            currentVal = max
        end
        local function snap(value)
            if max == min then
                return min
            end
            local scaled = (value - min) / step
            scaled = math.floor(scaled + 0.5)
            return min + scaled * step
        end
        local function formatValue(v)
            if decimals <= 0 then
                return tostring(math.floor(v + 0.5)) .. "  "
            end
            local fmt = "%." .. tostring(decimals) .. "f"
            return string.format(fmt, v) .. "  "
        end
        local function update(input)
            local pos
            if input then
                pos = math.clamp((input.Position.X - barBg.AbsolutePosition.X) / barBg.AbsoluteSize.X, 0, 1)
            else
                if max == min then
                    pos = 0
                else
                    pos = (currentVal - min) / (max - min)
                end
            end
            fill.Size = UDim2.fromScale(pos, 1)
            local raw = min + (max - min) * pos
            currentVal = snap(raw)
            val.Text = formatValue(currentVal)
            if callback then
                callback(currentVal)
            end
        end
        local active = false
        sFrame.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then active = true; update(input) end end)
        UserInputService.InputChanged:Connect(function(input) if active and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then update(input) end end)
        UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then active = false end end)
        update()

        Window.ElementRegistry[text] = {
            Type = "Slider",
            SetValue = function(v) 
                currentVal = snap(v)
                update() 
            end,
            GetValue = function() return currentVal end
        }
    end

