function isStageColor(c, potionType)
    local targetColor = nil
    if potionType == "Health Potion" then
        targetColor = Color3.fromRGB(99, 88, 89)
    elseif potionType == "Strength Potion" then
        targetColor = Color3.fromRGB(120, 105, 106)
    elseif potionType == "Swiftness Potion" then
        targetColor = Color3.fromRGB(135, 168, 169)
    elseif potionType == "Haste Potion" then
        targetColor = Color3.fromRGB(187, 193, 106)
    end
    
    if targetColor then
        local diff = (Vector3.new(c.R, c.G, c.B) - Vector3.new(targetColor.R, targetColor.G, targetColor.B)).Magnitude
        if diff < 0.02 then return true end
    end
    return false
end

function dropBatchFromInventory(itemName, amount)
    local function getInvCount(name)
        local mainGui = game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("MainGui")
        if not mainGui then return 0 end
        local inventory = mainGui.RightPanel and mainGui.RightPanel.Inventory and mainGui.RightPanel.Inventory.List
        if not inventory then return 0 end
        local item = inventory:FindFirstChild(name)
        if item then
            local attrCount = item:GetAttribute("Count") or item:GetAttribute("Amount") or item:GetAttribute("Quantity")
            if attrCount then return tonumber(attrCount) end
            local count = 0
            local qtyImage = item:FindFirstChild("QuantityImage")
            if qtyImage then
                local qtyText = qtyImage:FindFirstChild("QuantityText")
                if qtyText then count = tonumber(qtyText.Text) or 0 end
            end
            return count
        end
        return 0
    end

    local startTotal = getInvCount(itemName)
    local stabilityRetries = 0
    while stabilityRetries < 20 do
        task.wait(0.05)
        local check = getInvCount(itemName)
        if check == startTotal then break else startTotal = check end
        stabilityRetries = stabilityRetries + 1
    end
    
    if startTotal < amount then
        -- warn("[ASTER-BATCH] Not enough items! Have: " .. startTotal .. " Needed: " .. amount)
    end

    local failSafeTimer = tick()
    
    while true do
        local currentInv = getInvCount(itemName)
        local droppedTotal = startTotal - currentInv
        
        if droppedTotal >= amount then
            task.wait(0.25)
            local verifyInv = getInvCount(itemName)
            local verifyDropped = startTotal - verifyInv
            if verifyDropped >= amount then
                task.wait(0.25)
                local finalInv = getInvCount(itemName)
                if (startTotal - finalInv) >= amount then break end
            else
                currentInv = verifyInv
            end
        end
        
        if tick() - failSafeTimer > 20 then break end
        
        if (startTotal - getInvCount(itemName)) < amount then
            if drop then pcall(function() drop(itemName) end) end
            
            for _ = 1, 30 do
                task.wait(0.05)
                if getInvCount(itemName) < currentInv then break end
            end
            task.wait(0.1)
        end
    end
end

local cauldronHBOrig = {}
function expandCauldronHitboxOnce(c)
    if not c then return end
    local hb = c:FindFirstChild("Hitbox") or c:FindFirstChild("default")
    if not hb then return end
    if not cauldronHBOrig[c] then cauldronHBOrig[c] = hb.Size end
    hb.Size = Vector3.new(10000, 10000, 10000)
    hb.Transparency = 1
    hb.CanCollide = false
    hb.Massless = true
end

function shrinkCauldronHitbox(c)
    if not c then return end
    local hb = c:FindFirstChild("Hitbox") or c:FindFirstChild("default")
    local orig = cauldronHBOrig[c]
    if hb and orig then
        hb.Size = orig
        hb.Transparency = 1
    end
end

function setCauldronsTouchEnabled(list, enabled, except)
    for _, v in ipairs(list or {}) do
        if v ~= except then
            local hb = v:FindFirstChild("Hitbox") or v:FindFirstChild("default")
            if hb and hb:IsA("BasePart") then
