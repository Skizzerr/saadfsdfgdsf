function startCritterAura()
    if critterActive then return end
    critterActive = true
    
    local function getCritterID(model)
        -- 1. Check Cache
        if CritterIDCache[model] then return CritterIDCache[model] end
        
        -- 2. Check Whitelist (Avoid scanning non-critters)
        if not ValidCritters[model.Name] then return nil end
        
        -- 3. Scan for EntityID (Only done once per critter instance)
        local eid = nil
        -- Fast attribute check
        eid = model:GetAttribute("EntityID") or model:GetAttribute("ID")
        
        -- Deep scan if attribute missing
        if not eid then
            for name, value in pairs(model:GetAttributes()) do
                if typeof(value) == "number" and value > 1000 then eid = value break end
            end
        end
        if not eid then
             local val = model:FindFirstChildWhichIsA("IntValue", true) or model:FindFirstChildWhichIsA("NumberValue", true)
             if val and val.Value > 1000 then eid = val.Value end
        end
        
        -- 4. Cache Result
        if eid then
            CritterIDCache[model] = eid
        end
        return eid
    end
    

    local function hitTargets(eids)
        if #eids == 0 then return end
        local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        if not ByteNetReliable then return end

        local maxPackets = 4
        local hitsPerTarget = math.max(1, math.floor(maxPackets / #eids))
        local timeOffset = 0.01
        local baseTime = time() - (#eids * hitsPerTarget * timeOffset)
        
        local swingIdx = 0
        for i, eid in ipairs(eids) do
            for j = 1, hitsPerTarget do
                swingIdx = swingIdx + 1
                local b = buffer.create(4 + 4 + 19 + 8)
                buffer.writeu8(b, 0, 0)
                buffer.writeu8(b, 1, packetData().packets.SwingTool)
                buffer.writeu16(b, 2, 1) -- Force count to 1
                buffer.writeu32(b, 4, eid)
                writeByteNetCFrame(b, 8, hrp.CFrame)
                buffer.writef64(b, 27, baseTime + (swingIdx * timeOffset))
                ByteNetReliable:FireServer(b)
            end
        end
    end
    
    task.spawn(function()
        -- Attempt to pre-load ItemIDS if user wanted to use it for verification
        pcall(function()
             require(game:GetService("ReplicatedStorage").Modules.ItemIDS)
        end)
        
        local cachedCritters = {}
        local crittersFolder = workspace:FindFirstChild("Critters")
        local critterAddedConnection
        
        if crittersFolder then
            for _, critter in pairs(crittersFolder:GetChildren()) do
                if critter:IsA("Model") then
                    table.insert(cachedCritters, critter)
                end
            end
            critterAddedConnection = crittersFolder.ChildAdded:Connect(function(child)
                if child:IsA("Model") then
                    table.insert(cachedCritters, child)
                end
            end)
        end

        local lastCritterCacheUpdate = tick()
        
        while Settings.CritterAuraEnabled do
            pcall(function()
                local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                
                local now = tick()
                
                -- Fallback if folder was destroyed and recreated
                if not crittersFolder or not crittersFolder.Parent then
                    crittersFolder = workspace:FindFirstChild("Critters")
                    if crittersFolder then
                        if critterAddedConnection then critterAddedConnection:Disconnect() end
                        critterAddedConnection = crittersFolder.ChildAdded:Connect(function(child)
                            if child:IsA("Model") then table.insert(cachedCritters, child) end
                        end)
                    end
                end
                
                -- Fallback periodic full update (every 10 seconds) just to ensure cache consistency
                if crittersFolder and now - lastCritterCacheUpdate > 10 then
                    lastCritterCacheUpdate = now
                    table.clear(cachedCritters)
                    for _, critter in pairs(crittersFolder:GetChildren()) do
                        if critter:IsA("Model") then
                            table.insert(cachedCritters, critter)
                        end
                    end
                end
                
                local range = Settings.CritterRange or 15
                -- Extended detection range to register entities slightly before we reach them
                local detectionRange = range + 10 
                local rangeSq = range * range
                local detectionRangeSq = detectionRange * detectionRange
                
                local targetCount = tonumber(Settings.CritterTargetCount) or 3
                if targetCount < 1 then targetCount = 1 end
                
                local targetType = Settings.CritterType or "All"
                local targets = {}
                local hrpPos = hrp.Position
                
                -- Process from the pre-computed fast array cache instead of calling GetChildren() constantly
                local newCachedCritters = {}
                for i = 1, #cachedCritters do
                    local critter = cachedCritters[i]
                    if critter and critter.Parent == crittersFolder then
                        table.insert(newCachedCritters, critter)
                        
                        -- Use Optimized Cached Lookup
                        local eid = getCritterID(critter)
                        
                        if eid then
                            if targetType == "All" or critter.Name == targetType then
                                local ppart = critter.PrimaryPart or critter:FindFirstChildWhichIsA("BasePart")
                                if ppart then
                                    local diff = ppart.Position - hrpPos
                                    local distSq = diff:Dot(diff)
                                    
                                    -- Use extended detection range for collecting targets
                                    if distSq <= detectionRangeSq then 
                                        table.insert(targets, { eid = eid, distSq = distSq }) 
                                    end
                                end
                            end
                        end
                    end
                end
                cachedCritters = newCachedCritters
                
                if #targets > 0 then
                    table.sort(targets, function(a, b) return a.distSq < b.distSq end)
                    local selectedEids = {}
                    for i = 1, math.min(targetCount, #targets) do
                        if targets[i].distSq <= rangeSq then
                            table.insert(selectedEids, targets[i].eid)
                        end
                    end
                    if #selectedEids > 0 then
                        hitTargets(selectedEids)
                    end
                end
            end)
            task.wait(Settings.CritterCooldown or 0.03)
        end
        if critterAddedConnection then
            critterAddedConnection:Disconnect()
        end
        critterActive = false
    end)
end

