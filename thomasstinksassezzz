                             if not highlights[char] then
                                 local adorn = char
                                 
                                 local h = Instance.new("Highlight")
                                 h.FillColor = Color3.fromRGB(255, 215, 0) -- Gold for Players
                                 h.OutlineColor = Settings.ESPColors["GodESP"] or Color3.fromRGB(255, 255, 0) -- Dynamic Outline Color
                                 h.FillTransparency = 0.5
                                 h.OutlineTransparency = 0
                                 h.Adornee = char
                                 h.Parent = char
                                 
                                 local bg = Instance.new("BillboardGui")
