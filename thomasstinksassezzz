    for i = 1, maxn do table.insert(out, list[i].model) end
    return out
end

function dropBatchFromInventory(itemName, amount)
    local startTotal = getInventoryCount(itemName)
    local stabilityRetries = 0
    while stabilityRetries < 20 do
        task.wait(0.05)
        local check = getInventoryCount(itemName)
        if check == startTotal then break else startTotal = check end
        stabilityRetries = stabilityRetries + 1
    end
    
    local failSafeTimer = tick()
    while true do
        local currentInv = getInventoryCount(itemName)
        local droppedTotal = startTotal - currentInv
        if droppedTotal >= amount then break end
        if tick() - failSafeTimer > 20 then break end
        
        if (startTotal - getInventoryCount(itemName)) < amount then
            drop(itemName)
            for _ = 1, 30 do
                task.wait(0.03)
                if getInventoryCount(itemName) < currentInv then break end
            end
        end
    end
end



