-- [[ QUICK HUT LOGIC ]] --
function executeQuickHutScan()
    local plr = game:GetService("Players").LocalPlayer
    
    local function getPlayerItems(p)
        local items = {}
        if p.Character then
            for _, child in ipairs(p.Character:GetChildren()) do
                local id = child:GetAttribute("ItemID") or child:GetAttribute("itemID") or child:GetAttribute("ID")
                if id then items[tonumber(id)] = true end
            end
        end
        return items
    end

    local function hasGodSet(p)
        local items = getPlayerItems(p)
        return items[16] and items[26] and items[288]
    end

    local function placeHutOnPlayer(targetPlayer)
        if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character.PrimaryPart then return end
        local pos = targetPlayer.Character.PrimaryPart.Position

        local packetId = packetData().packets.PlaceStructure
        if not packetId then return end
        
        if ByteNetReliable then
            local hutNames = {"Big Ol' Hut", "Hut", "Shelter"}
            for _, hutName in ipairs(hutNames) do
                local len = #hutName
                local b = buffer.create(4 + len + 18)
                buffer.writeu8(b, 0, 0)
                buffer.writeu8(b, 1, packetId)
                buffer.writeu16(b, 2, len)
                buffer.writestring(b, 4, hutName)
                
                local offset = 4 + len
                write18ByteCFrame(b, offset, CFrame.new(pos))
                
                ByteNetReliable:FireServer(b)
                task.wait(0.01)
            end
        end
    end

    local myPos = plr.Character and plr.Character.PrimaryPart and plr.Character.PrimaryPart.Position
    if not myPos then return end
    
    local bestTarget = nil
    local bestDist = 999999
    
    local fallbackTarget = nil
    local fallbackDist = 999999
    
    for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
        if p ~= plr and p.Character and p.Character.PrimaryPart then
            local isTargetable = true
            
            -- Check Teams
            local myTeam = plr.Team
            local noTribe = game:GetService("Teams"):FindFirstChild("NoTribe")
            
            if myTeam and myTeam ~= noTribe and p.Team == myTeam then
                isTargetable = false
            end

            if isTargetable and isAlly(p) then
                isTargetable = false
            end
            
            if isTargetable then
                local dist = (p.Character.PrimaryPart.Position - myPos).Magnitude
                
                if hasGodSet(p) then
                    if dist < bestDist then
                        bestDist = dist
                        bestTarget = p
                    end
                end
                
                if dist < fallbackDist then
                    fallbackDist = dist
                    fallbackTarget = p
                end
            end
        end
    end
    
    local finalTarget = bestTarget or fallbackTarget
    if finalTarget then
        placeHutOnPlayer(finalTarget)
    end
end



local plantActive = false
function startPlant()
    if plantActive then return end
    plantActive = true
    task.spawn(function()
        if not game:IsLoaded() then game.Loaded:Wait() end
        task.wait(0.5)
        
        local ItemIDS = require(game:GetService("ReplicatedStorage").Modules.ItemIDS)
        
        -- [[ PHYSICS OPTIMIZATION: Reuse Params ]] --
        -- Creating this once instead of every frame saves memory and GC overhead
        local overlapParams = OverlapParams.new()
        overlapParams.FilterDescendantsInstances = {plr.Character}
        overlapParams.FilterType = Enum.RaycastFilterType.Exclude
        
        -- Pre-allocate tables
        local plantboxes = {}
        local seen = {}
        
        while Settings.PlantEnabled do
            pcall(function()
                local char = plr.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                
                local range = tonumber(Settings.PlantRange) or 20
                local rangeSq = range * range
                
                local selectedFruit = Settings.PlantFruit or "Bloodfruit"
                local itemID = ItemIDS[selectedFruit.." Seed"] or ItemIDS[selectedFruit]
                
                -- [[ PHYSICS QUERY ]] --
                -- This uses C++ Spatial Hashing which is faster than iterating a Lua table for large maps
                local parts = workspace:GetPartBoundsInRadius(hrp.Position, range, overlapParams)
                
                table.clear(plantboxes)
                table.clear(seen)
                local hrpPos = hrp.Position
                
                for _, part in ipairs(parts) do
                    local model = part.Parent
                    if model and model.Name == "Plant Box" then
                        local eid = model:GetAttribute("EntityID")
                        if eid and not seen[eid] then
                            -- Debounce check early
                            if plantedboxes[eid] and (os.clock() - plantedboxes[eid] < 0.2) then continue end
                            
                            local pp = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
                            if pp then
                                seen[eid] = true
                                -- [[ MATH OPTIMIZATION ]] --
                                local diff = pp.Position - hrpPos
                                local distSq = diff:Dot(diff) -- Faster than Magnitude
                                
                                table.insert(plantboxes, { 
                                    entityid = eid, 
                                    deployable = model, 
                                    distSq = distSq 
                                })
                            end
                        end
                    end
                end
                
                table.sort(plantboxes, function(a, b) return a.distSq < b.distSq end)
                
                local plantedCount = 0
                local now = os.clock()
                
                for i, box in ipairs(plantboxes) do
                    if not Settings.PlantEnabled then break end
                    
                    -- Double check range (in case player moved fast)
                    if box.distSq <= rangeSq then
                        if not box.deployable:FindFirstChild("Seed") then
                            plant(box.entityid, itemID)
                            plantedCount = plantedCount + 1
                        else
                            plantedboxes[box.entityid] = now
                        end
                    end
                    if plantedCount >= 25 then break end
                end
            end)
            
            local delay = Settings.PlantDelay or 0.01
            if delay < 0.02 then task.wait() else task.wait(delay) end
        end
        plantActive = false
    end)
end

local harvestActive = false
function startHarvest()
    if harvestActive then return end
    harvestActive = true
    task.spawn(function()
        local attemptedItems = {}
        local pickupPacketID = packetData() and packetData().packets and packetData().packets.Pickup
        
        while true do
            if not Settings.HarvestEnabled then
                harvestActive = false
                break
            end
            
            pcall(function()
                local currentTime = tick()
                -- Cleanup old attempted items
                for item, attemptTime in pairs(attemptedItems) do
                    if currentTime > attemptTime then 
                        attemptedItems[item] = nil
                    end
                end

                local range = tonumber(Settings.HarvestRange) or 25
                local fruit = tostring(Settings.PlantFruit) or "Bloodfruit"
                local items = getHarvestables(range, fruit)

                if #items > 0 then
                    -- Efficiently sort items by distance
                    table.sort(items, function(a, b) 
                        return (a.distSq or plr:GetAttribute("DistSq")) < (b.distSq or plr:GetAttribute("DistSq")) 
                    end)
                    
                    -- Dynamically adjust batch size for efficiency
                    local batchSize = math.min(tonumber(Settings.HarvestBatchSize) or 150, #items)
                    local harvestedCount = 0
        
                    for i, item in ipairs(items) do
                        if not Settings.HarvestEnabled then break end
                        if harvestedCount >= batchSize then break end
                        
                        local eid = item.entityid
                        if not eid and item.model then
                             eid = item.model:GetAttribute("ID") or item.model:GetAttribute("NetworkID") or item.model:GetAttribute("EntityID")
                        end
                        
                        if eid and ByteNetReliable and pickupPacketID and not attemptedItems[eid] then
                            attemptedItems[eid] = currentTime + 0.3
                            local itemID = autoDiscoverItemID(item.model and item.model.Name or "") or 0
                            local b = buffer.create(8)
                            buffer.writeu8(b, 0, 0)
                            buffer.writeu8(b, 1, pickupPacketID)
                            buffer.writeu32(b, 2, eid)
                            buffer.writeu16(b, 6, itemID)
                            ByteNetReliable:FireServer(b)
                            harvestedCount = harvestedCount + 1
                            
                            if harvestedCount % 50 == 0 then
                                task.wait()
                            end
                        end
                    end
                end
            end)
            task.wait(0.05)
        end
    end)
end


local sandActive = false
local lastPickSwap = 0
local harvesting = false
function startAutoSand()
    if sandActive then return end
    sandActive = true
    local lockedY = nil

    -- GUI Trigger Connection (Fallback)
    local guiConnection = plr.PlayerGui.DescendantAdded:Connect(function(obj)
        if not Settings.AutoSandEnabled then return end
        if obj:IsA("TextLabel") and obj.Text:find("Break one of your sand mounds!") then
            harvesting = true
        end
    end)

    -- Main Loop
    task.spawn(function()
        while Settings.AutoSandEnabled do
            -- Count actual mounds around the player
            local nearbyMounds = 0
            local root = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if root then
                 local allResources = workspace.Resources:GetChildren()
                 for _, r in ipairs(allResources) do
                     if r.Name == "Sand Mound" then
                         if (r:GetPivot().Position - root.Position).Magnitude <= 30 then
                             nearbyMounds = nearbyMounds + 1
                         end
                     end
                 end
            end

            -- State Transitions
            if not harvesting and nearbyMounds >= 9 then
                harvesting = true
            elseif harvesting and nearbyMounds == 0 then
                harvesting = false
                
                -- Force Unequip Pickaxe before equipping Shovel
                local char = plr.Character
                local hum = char and char:FindFirstChild("Humanoid")
                if hum then
                    hum:UnequipTools()
                end
            end

            if harvesting then
                -- HARVESTING STATE: Equip Pickaxe and Swing
                pcall(function()
                    local pickName = "God Pick"
                    local char = plr.Character
                    local isEquipped = char and char:FindFirstChild(pickName)
                    
                    if not isEquipped then
                        local pickSlot = getToolSlot(pickName)
                        if pickSlot then
                            equipItemPacket(pickName)
                            task.wait(0.02) 
                        end
                    end
                    
                    if not char:FindFirstChild(pickName) then
                         local bpTool = plr.Backpack:FindFirstChild(pickName)
                         if bpTool and char:FindFirstChild("Humanoid") then
                             char.Humanoid:EquipTool(bpTool)
                             task.wait(0.01)
                         end
                    end

                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if hrp and ByteNetReliable then
                         local resources = workspace:FindFirstChild("Resources")
                         local eids = {}
                         if resources then
                             for _, m in ipairs(resources:GetChildren()) do
                                 if m.Name == "Sand Mound" then
                                     if (m:GetPivot().Position - hrp.Position).Magnitude <= 30 then
                                         local id = m:GetAttribute("EntityID")
                                         if id then table.insert(eids, id) end
                                     end
                                 end
                             end
                         end

                         if #eids > 0 then
                             local maxPackets = 4
                             local hitsPerTarget = math.max(1, math.floor(maxPackets / #eids))
                             local timeOffset = 0.01
                             local baseTime = time() - (#eids * hitsPerTarget * timeOffset)
                             local swingIdx = 0
                             
                             for i, eid in ipairs(eids) do
                                 for j = 1, hitsPerTarget do
                                     swingIdx = swingIdx + 1
                                     local b = buffer.create(4 + 4 + 19 + 8)
                                     buffer.writeu8(b, 0, 0)
                                     buffer.writeu8(b, 1, packetData().packets.SwingTool)
                                     buffer.writeu16(b, 2, 1) -- Force count to 1
                                     buffer.writeu32(b, 4, eid)
                                     writeByteNetCFrame(b, 8, hrp.CFrame)
                                     buffer.writef64(b, 27, baseTime + (swingIdx * timeOffset))
                                     ByteNetReliable:FireServer(b)
                                 end
                             end
                         else
                             local b = buffer.create(4 + 19 + 8)
                             buffer.writeu8(b, 0, 0)
                             buffer.writeu8(b, 1, packetData().packets.SwingTool)
                             buffer.writeu16(b, 2, 0)
                             local offset = 4
                             writeByteNetCFrame(b, offset, hrp.CFrame)
                             offset = offset + 19
                             buffer.writef64(b, offset, time())
                             ByteNetReliable:FireServer(b)
                         end
                    end
                end)
                task.wait(0.1) -- Delay between swings while harvesting
            else
                -- DIGGING STATE: Equip Shovel and Dig
                pcall(function()
                    local char = plr.Character
                    local root = char and char:FindFirstChild("HumanoidRootPart")
                    
                    if root then
                        local tools = workspace.Players[plr.Name]:FindFirstChild("Tools")
                    
                    -- Aggressive Equip: If Shovel missing, Equip & Dig anyway (Trust Packet Order)
                    if tools and not tools:FindFirstChild("Shovel") then
                        local shovelName = "Shovel"
                        if getToolSlot(shovelName) then 
                             equipItemPacket(shovelName)
                        end
                    end
                    
                    -- REMOVED: The wait and the return check. 
                    -- We now proceed to dig immediately after sending equip packet.
                    -- This ensures 0-latency resumption.

                    if lockedY == nil then
                        lockedY = root.Position.Y - (Settings.SandHeight or 3)
                    end
                    
                    -- Dig twice per spot (2 vertical layers) across a 3x3 grid
                    local layerOffsets = {0, -0.5}
                    local gridOffsets = {{0,0}, {5,0}, {-5,0}, {0,5}, {5,5}, {-5,5}, {0,-5}, {5,-5}, {-5,-5}}
                    
                    for _, offset in ipairs(gridOffsets) do
                        if harvesting or not Settings.AutoSandEnabled then break end
                        
                        -- Update center dynamically so user can "dig along" as they walk
                        local char = plr.Character
                        local currentRoot = char and char:FindFirstChild("HumanoidRootPart")
                        if not currentRoot then break end
                        
                        local centerX = math.floor(currentRoot.Position.X + 0.5)
                        local centerZ = math.floor(currentRoot.Position.Z + 0.5)
                        
                        -- Adjust lockedY if player moved significantly up or down (hills)
                        if math.abs((currentRoot.Position.Y - (Settings.SandHeight or 3)) - lockedY) > 4 then
                             lockedY = currentRoot.Position.Y - (Settings.SandHeight or 3)
                        end
                        
                        for _, yOff in ipairs(layerOffsets) do
                            if harvesting or not Settings.AutoSandEnabled then break end
                            local currentY = lockedY + yOff
                            
                            local targetPos = Vector3.new(centerX + offset[1], currentY, centerZ + offset[2])
                            
                            local currentResources = workspace.Resources:GetChildren()
                            
                            -- PRIORITIZE UPGRADING: Dig existing mounds FIRST (L1 -> L2)
                            -- We scan specifically for Level 1 Mounds (usually named "_MOUND" or have specific mesh ID, but name is reliable enough)
                            for _, m in ipairs(currentResources) do
                                if (m.Name == "_MOUND" or m.Name == "Sand Mound") then
                                    local mPos = m:GetPivot().Position
                                    -- Check if this mound is close enough to our target grid point
                                    local dist = (Vector2.new(mPos.X, mPos.Z) - Vector2.new(targetPos.X, targetPos.Z)).Magnitude
                                    
                                    -- Distance check: 2.5 is standard, but we'll use 3.0 to be generous
                                    if dist < 3.0 then 
                                        local id = m:GetAttribute("EntityID")
                                        if id then 
                                            -- Send dig packet specifically targeting the mound ID
                                            -- This packet upgrades L1 -> L2
                                            pcall(function() 
                                                if ByteNetReliable then
                                                    local b = buffer.create(19)
                                                    buffer.writeu8(b, 0, 0)
                                                    buffer.writeu8(b, 1, packetData().packets.Dig)
                                                    buffer.writef32(b, 2, mPos.X)
                                                    buffer.writef32(b, 6, mPos.Y)
                                                    buffer.writef32(b, 10, mPos.Z)
                                                    buffer.writeu8(b, 14, 1)
                                                    buffer.writeu32(b, 15, id)
                                                    ByteNetReliable:FireServer(b)
                                                end
                                            end) 
                                        end
                                    end
                                end
                            end
                            
                            -- THEN Dig Ground (Spawn new mound)
                            pcall(function() 
                                if ByteNetReliable then
                                    local b = buffer.create(15)
                                    buffer.writeu8(b, 0, 0)
                                    buffer.writeu8(b, 1, packetData().packets.Dig)
                                    buffer.writef32(b, 2, targetPos.X)
                                    buffer.writef32(b, 6, targetPos.Y)
                                    buffer.writef32(b, 10, targetPos.Z)
                                    buffer.writeu8(b, 14, 0)
                                    ByteNetReliable:FireServer(b)
                                end
                            end)
                            
                            task.wait(Settings.SandFarmSpeed or 0.1)
                        end
                    end
                    end -- End of if root then
                end)
            end

            task.wait()
        end

        if guiConnection then guiConnection:Disconnect() end
        lockedY = nil
        sandActive = false
    end)
end

