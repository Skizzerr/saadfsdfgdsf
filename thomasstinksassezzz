                        if visual.Parent ~= hrp then
                            visual.Anchored = false -- Ensure unanchored before welding
                            visual.Parent = hrp
                            visual.CFrame = hrp.CFrame * CFrame.new(0, -2.9, 0) * CFrame.Angles(0, 0, math.rad(90))

                            if weld then weld:Destroy() end
                            weld = Instance.new("WeldConstraint")
                            weld.Part0 = hrp
                            weld.Part1 = visual
                            weld.Parent = hrp
                        end

                        visual.Size = Vector3.new(0.2, range * 2, range * 2)
                        visual.Transparency = 0.6
                    else
                        visual.Transparency = 1
                        if weld then weld:Destroy() weld = nil end
                        visual.Parent = workspace
                        visual.CFrame = CFrame.new(0, -1000, 0)
                        visual.Anchored = true
                    end

                    -- Targeting Logic
                    local hrpPos = hrp.Position
                    local detectionRange = range + 10
                    local rangeSq = range * range
                    local detectionRangeSq = detectionRange * detectionRange

                    for _, other in ipairs(game:GetService("Players"):GetPlayers()) do
                        if other ~= plr and other.Character then
                            local char = other.Character
                            local eid = findNetworkID(char) or char:GetAttribute("EntityID")
                            local ppart = char:FindFirstChild("HumanoidRootPart")

                            local isTargetable = true

                            -- Team Logic:
                            -- 1. If myTeam is nil or NoTribe, we are hostile to everyone (isTargetable remains true).
                            -- 2. If we have a team (and not NoTribe), we ignore teammates.
                            if myTeam and myTeam ~= noTribe then
                                if other.Team == myTeam then
                                    isTargetable = false
                                end
                            end

                            -- 3. Check for Allies
                            if isTargetable and isAlly(other) then
                                isTargetable = false
                            end

                            if isTargetable and eid and ppart then
                                local diff = ppart.Position - hrpPos
                                local distSq = diff:Dot(diff)

                                -- Use Cylindrical Check concept but optimized with Squared Distance
                                -- distSq includes Y difference, so we check total 3D distance first for optimization
                                if distSq <= detectionRangeSq then
                                    local flatDiff = Vector3.new(diff.X, 0, diff.Z)
                                    local flatDistSq = flatDiff:Dot(flatDiff)
                                    local yDist = math.abs(diff.Y)

                                    -- Precise check: Horizontal range + vertical tolerance (20 studs)
                                    if flatDistSq <= detectionRangeSq and yDist <= 20 then
                                        table.insert(targets, { eid = eid, distSq = flatDistSq, rangeSq = rangeSq })
                                    end
                                end
                            end
