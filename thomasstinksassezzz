            Settings.FreeCamPitch = math.deg(rx)

            -- Roblox Studio-style scroll wheel speed control
            freecamScrollConnection = UserInputService.InputChanged:Connect(function(input)
                if Settings.FreeCam and input.UserInputType == Enum.UserInputType.MouseWheel then
                    local currentSpeed = Settings.FreeCamSpeed or 5
                    local multiplier = 1.1
                    local newSpeed
                    if input.Position.Z > 0 then
                        newSpeed = currentSpeed / multiplier -- Closer is slower
                    else
                        newSpeed = currentSpeed * multiplier -- Farther is faster
                    end
                    
                    newSpeed = math.clamp(newSpeed, 0.5, 250)
                    Settings.FreeCamSpeed = newSpeed
                    
                    if freecamSpeedSlider and freecamSpeedSlider.SetValue then
                        freecamSpeedSlider:SetValue(newSpeed)
                    end
                end
            end)
