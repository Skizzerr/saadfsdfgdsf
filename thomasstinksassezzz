local function getDockPreviewModel()
    local rs = game:GetService("ReplicatedStorage")
    local template = nil
    
    local quickFolders = {"Deployables", "PlaceStructures", "Structures", "Models"}
    for _, fname in ipairs(quickFolders) do
        local folder = rs:FindFirstChild(fname)
        if folder and folder:FindFirstChild("Dock") then
            template = folder:FindFirstChild("Dock")
            break
        end
    end
    
    if not template then
        for _, v in ipairs(rs:GetDescendants()) do
            if (v:IsA("Model") or v:IsA("BasePart")) and v.Name == "Dock" then
                template = v
                break
            end
        end
    end
    
    local model
    local heightOffset = 0.5
    
    if template and (template:IsA("Model") or template:IsA("BasePart")) then
        model = template:Clone()
        if model:IsA("Model") then
            local _, size = model:GetBoundingBox()
            heightOffset = size.Y / 2
            
            for _, part in ipairs(model:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Anchored = true
                    part.CanCollide = false
                    part.CastShadow = false
                    part.Transparency = 0.5
                    pcall(function()
                        part.CanQuery = false
                        part.CanTouch = false
                    end)
                end
            end
        elseif model:IsA("BasePart") then
            heightOffset = model.Size.Y / 2
            model.Anchored = true
            model.CanCollide = false
            model.CastShadow = false
            model.Transparency = 0.5
            pcall(function()
                model.CanQuery = false
                model.CanTouch = false
            end)
        end
    else
        model = Instance.new("Part")
        model.Size = Vector3.new(10, 1, 10)
        model.Color = Color3.fromRGB(139, 90, 43)
        model.Material = Enum.Material.Wood
        model.Anchored = true
        model.CanCollide = false
        model.CastShadow = false
        model.Transparency = 0.5
        pcall(function()
            model.CanQuery = false
            model.CanTouch = false
        end)
        heightOffset = 0.5
    end
    
    model.Name = "PreviewDock"
    model:SetAttribute("PreviewHeightOffset", heightOffset)
    return model
end

DockAnchor = nil
local pendingDockPlacements = {} -- define at scope level so updateDockPreview can read it

local function updateDockPreview()
    -- Show preview ONLY if the Dock Preview toggle is turned on
    if not Settings.ShowDockPreview then
        for _, model in pairs(DockPreviewCache) do
            if model then model:Destroy() end
        end
        table.clear(DockPreviewCache)
        table.clear(DockGroundHeightCache)
        table.clear(DockOccupancyCache)
        return
    end
    
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local currentTime = tick()
    
    if not CachedDockRayParams or (currentTime - LastDockParamsUpdate > 2.0) then
        local rayParams = RaycastParams.new()
        local ignoreList = {}
        if plr.Character then table.insert(ignoreList, plr.Character) end
        if PreviewContainer then table.insert(ignoreList, PreviewContainer) end
        if DockPreviewContainer then table.insert(ignoreList, DockPreviewContainer) end
        
        local ignoreFolders = {"Resources", "Rubble", "Critters", "Items", "Players", "MeteorParts"}
        for _, name in ipairs(ignoreFolders) do
            local f = workspace:FindFirstChild(name)
            if f then table.insert(ignoreList, f) end
        end
        rayParams.FilterDescendantsInstances = ignoreList
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        rayParams.IgnoreWater = false -- Docks can be placed on water
        
        CachedDockRayParams = rayParams
        LastDockParamsUpdate = currentTime
    end
    
    local baseGridCFrame = CFrame.new(0,0,0, -0.551313877, 0, -0.834298372, 0, 1, 0, 0.834298372, 0, -0.551313877) * CFrame.Angles(0, math.rad(Settings.DockRotation or 0), 0)
     
    local Z_GAP = 32.0
    local X_GAP = 13.0
    
    local centerPos = hrp.Position
    local localPos = baseGridCFrame:PointToObjectSpace(centerPos)
    local baseRow = DockAnchor and DockAnchor.row or math.floor(localPos.Z / Z_GAP + 0.5)
    local baseCol = DockAnchor and DockAnchor.col or math.floor(localPos.X / X_GAP + 0.5)
    
    local amount = Settings.DockAmount or 9
    local shape = Settings.DockShape or "Square"
    local offsets = {}

    if shape == "Rectangle" then
        local cols = math.max(1, math.ceil(math.sqrt(amount / 2)))
        local rows = math.ceil(amount / cols)
        -- Start exactly at the player's column and build right
        local r0 = 0 
        local c0 = 0 
        local count = 0
        for c = 0, cols-1 do
            for r = 0, rows-1 do
                if count < amount then
                    table.insert(offsets, {r = r0 + r, c = c0 + c})
                    count = count + 1
                end
            end
        end
    else
        local side = math.max(1, math.ceil(math.sqrt(amount)))
        -- Start exactly at the player's column and build right
        local r0 = 0 
        local c0 = 0 
        local count = 0
        for r = 0, side-1 do
            for c = 0, side-1 do
                if count < amount then
                    table.insert(offsets, {r = r0 + r, c = c0 + c})
                    count = count + 1
                end
            end
        end
    end
    
    local activeKeys = {}
    
    for _, off in ipairs(offsets) do
        local localTarget = Vector3.new((baseCol + off.c) * X_GAP, 0, (baseRow + off.r) * Z_GAP)
        local worldTarget = baseGridCFrame:PointToWorldSpace(localTarget)
        local targetX = worldTarget.X
        local targetZ = worldTarget.Z
        local key = string.format("%.1f,%.1f", targetX, targetZ)
        
        activeKeys[key] = true
        
        local cellY = hrp.Position.Y - 3
        local cached = DockGroundHeightCache[key]
        
        if cached and (currentTime - cached.t < 3.0) then
            cellY = cached.y
        else
            local rayOrigin = Vector3.new(targetX, hrp.Position.Y + 30, targetZ)
            local rayDir = Vector3.new(0, -500, 0)
            local hit = workspace:Raycast(rayOrigin, rayDir, CachedDockRayParams)
            
            if hit then
                cellY = hit.Position.Y
                DockGroundHeightCache[key] = {y = cellY, t = currentTime}
            else
                DockGroundHeightCache[key] = {y = cellY, t = currentTime}
            end
        end
        
        local occupied = false
        local occCached = DockOccupancyCache[key]
        
        if occCached and (currentTime - occCached.t < 0.25) then
            occupied = occCached.val
        else
            local checkCFrame = CFrame.new(Vector3.new(targetX, cellY + 5, targetZ)) * baseGridCFrame.Rotation
            local checkSize = Vector3.new(4, 100, 4) 
            local parts = workspace:GetPartBoundsInBox(checkCFrame, checkSize)
            
            for _, p in ipairs(parts) do 
                local model = p:FindFirstAncestorOfClass("Model")
                if model and model.Name == "Dock" then
                     local pPos = model:GetPivot().Position
                     local distToCenter = math.sqrt((pPos.X - targetX)^2 + (pPos.Z - targetZ)^2)
                     if distToCenter < 2.0 then
                        occupied = true 
                        break 
                     end
                end 
            end
            DockOccupancyCache[key] = {val = occupied, t = currentTime}
        end
        
        if not occupied and not pendingDockPlacements[key] then
            local model = DockPreviewCache[key]
            if not model then
                model = getDockPreviewModel()
                model.Parent = DockPreviewContainer
                DockPreviewCache[key] = model
            end
            
            local heightOffset = model:GetAttribute("PreviewHeightOffset") or 0.5
            local targetCFrame = CFrame.new(Vector3.new(targetX, cellY + heightOffset, targetZ)) * baseGridCFrame.Rotation
            
            if model:IsA("Model") then
                model:PivotTo(targetCFrame)
            elseif model:IsA("BasePart") then
                model.CFrame = targetCFrame
            end
        else
            if DockPreviewCache[key] then
                DockPreviewCache[key]:Destroy()
                DockPreviewCache[key] = nil
            end
        end
    end
    
    for key, model in pairs(DockPreviewCache) do
        if not activeKeys[key] then
            model:Destroy()
            DockPreviewCache[key] = nil
            if DockGroundHeightCache[key] then DockGroundHeightCache[key] = nil end
            if DockOccupancyCache[key] then DockOccupancyCache[key] = nil end
        end
    end
end

