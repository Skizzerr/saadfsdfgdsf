                        anim.AnimationId = targetAnimId
                        animTrack = animator:LoadAnimation(anim)
                    end
                end
                if animTrack then
                    animTrack:Play()
                end
            end
        end
        
        while Settings.PlayerAuraEnabled do
            pcall(function()
                local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")



                if hrp then
                    local range = Settings.PlayerAuraRange or 8
                    local targets = {}

