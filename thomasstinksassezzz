                                -- Apply if different
                                if math.abs(hrp.Size.X - finalSize) > 0.1 then
                                    hrp.Size = Vector3.new(finalSize, finalSize, finalSize)
                                    hrp.CanCollide = false
                                end
                                
                                -- Handle Visuals using SelectionBox (Visible even if camera is inside)
                                local box = hrp:FindFirstChild("HitboxVisual")
                                if not box then
                                    box = Instance.new("SelectionBox")
                                    box.Name = "HitboxVisual"
                                    box.Adornee = hrp
                                    box.Parent = hrp
                                end
                                
                                if visuals then
                                    box.Color3 = Color3.fromRGB(255, 0, 0)
                                    box.LineThickness = 0
                                    box.Transparency = 1 -- Hide Lines
                                    box.SurfaceTransparency = 0.8 -- Semi-transparent fill
                                    box.SurfaceColor3 = Color3.fromRGB(255, 0, 0)
                                    box.Visible = true
                                    
                                    -- Keep part invisible to avoid rendering issues/conflicts
                                    if hrp.Transparency ~= 1 then hrp.Transparency = 1 end
                                else
                                    box.Visible = false
                                    if hrp.Transparency ~= 1 then hrp.Transparency = 1 end
                                end
                            else
                                 -- Reset if expanded (or if they became ally)
                                 if hrp.Size.X > 2.1 or hrp.Transparency == 0.7 then
                                     hrp.Size = Vector3.new(2, 2, 1)
                                     hrp.Transparency = 1
                                     hrp.BrickColor = BrickColor.new("Medium stone grey")
                                     hrp.Material = Enum.Material.Plastic
                                     hrp.CanCollide = true
                                 end
                                 
                                 local box = hrp:FindFirstChild("HitboxVisual")
                                 if box then box:Destroy() end
                            end
                        end
                    end
                 end
            end)
        end)
    end)
end


