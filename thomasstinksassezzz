local potionChestActive = false
function startPotionChestEngine()
    if potionChestActive then return end
    potionChestActive = true
    task.spawn(function()
        while Settings.TeleportPotionsToChest do
            local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local deployables = workspace:FindFirstChild("Deployables")
                local items = workspace:FindFirstChild("Items")
                if deployables and items then
                    -- 1. Find Nearest Chest
                    local nearestChest = nil
                    local minDist = 60 -- Max range
                    
                    for _, obj in ipairs(deployables:GetChildren()) do
                        if (obj.Name:find("Chest") or obj.Name:find("Box")) and not obj.Name:find("Plant Box") then
                            local pivot = obj:GetPivot().Position
                            local dist = (pivot - hrp.Position).Magnitude
                            if dist < minDist then
                                minDist = dist
                                nearestChest = obj
                            end
                        end
                    end
                    
                    -- 2. Teleport Potions
                    if nearestChest and nearestChest:FindFirstChild("Contents") then
                        local targetPart = nearestChest:FindFirstChild("Hitbox")
                        local targetCFrame = targetPart and targetPart.CFrame or nearestChest:GetPivot()

                        for _, item in ipairs(items:GetChildren()) do
                            if item.Name:find("Potion") then
                                local root = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
                            if root then
                                root.CFrame = targetCFrame
                                root.AssemblyAngularVelocity = Vector3.zero
                                root.AssemblyLinearVelocity = Vector3.new(0, -2, 0)
                                
                                -- Anti-Desync Enforcement
                                task.spawn(function()
                                    local retries = 0
                                    while item and item.Parent == workspace.Items and retries < 10 do
                                        if root then
                                            root.CFrame = targetCFrame
                                            root.AssemblyAngularVelocity = Vector3.zero
                                            root.AssemblyLinearVelocity = Vector3.new(0, -2, 0)
                                        end
                                        retries = retries + 1
                                        task.wait(0.1)
                                    end
                                end)
                                -- item.Parent = nearestChest.Contents -- Disabled direct parenting
                            end
                            end
                        end
                    end
                end
            end
            task.wait(0.5)
        end
        potionChestActive = false
    end)
end

