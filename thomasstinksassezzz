task.spawn(function()
    local savedAutoLoadName = ASTER.ConfigSystem.GetAutoLoad()
    local availableConfigs = ASTER.ConfigSystem.GetConfigs()
    local targetConfig = nil
    
    -- 1. Check if the saved config still exists
    if savedAutoLoadName and savedAutoLoadName ~= "" then
        for _, name in ipairs(availableConfigs) do
            if name == savedAutoLoadName then
                targetConfig = savedAutoLoadName
                break
            end
        end
        
        -- 2. If saved config is missing/invalid, try to find the "newest" (or last available)
        if not targetConfig and #availableConfigs > 0 then
            targetConfig = availableConfigs[#availableConfigs] -- Selects the last config in the list
        end
    end

    -- 3. Execute Selection & Loading
    if targetConfig then
        -- Update Visuals
        Settings.SelectedConfig = targetConfig
        if ASTER.Options.ConfigDropdown then 
            ASTER.Options.ConfigDropdown:SetValue(targetConfig) 
        end

        -- Load the Config
        if isfile(ASTER.ConfigFolder .. "/" .. targetConfig .. ".json") then
            ASTER.ConfigSystem.LoadConfig(targetConfig)
        end

        -- Force Toggle ON & Update Persistence
        Settings.AutoLoadSelected = true
        local autoLoadToggle = Window.ElementRegistry["Auto Load Selected"]
        if autoLoadToggle and autoLoadToggle.SetValue then 
            autoLoadToggle.SetValue(true) 
        end
        
        -- If we had to switch configs (e.g. from invalid 'yes' to 'omg'), save the new one
        if targetConfig ~= savedAutoLoadName then
            ASTER.ConfigSystem.SetAutoLoad(targetConfig)
        end
    end
end)

