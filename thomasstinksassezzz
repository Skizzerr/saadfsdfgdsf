                                bg.Adornee = char:FindFirstChild("Head") or char.PrimaryPart
                                bg.Size = UDim2.new(0, 200, 0, 50)
                                bg.StudsOffset = Vector3.new(0, 5.0, 0) -- Match PlayerESP (was 6.5)
                                bg.AlwaysOnTop = true
                                 
