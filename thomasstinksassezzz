                                            local success, name = pcall(function() return v.Name end)
                                            if success and (name == "Coin Stack" or name == "Essence Stack" or name:find("Drop")) then
                                                table.insert(newNilCache, v)
                                                addedCount = addedCount + 1
                                                if addedCount > 1500 then break end
                                            end
                                        end
                                        if i % 3000 == 0 then task.wait() end
                                    end
                                end)
                                Settings.CachedNilItems = newNilCache
                            end)
                        end
                        
                        if Settings.CachedNilItems then
                            for _, v in ipairs(Settings.CachedNilItems) do
                                scanCount = scanCount + 1
                                if scanCount % 500 == 0 then
                                    task.wait()
                                    if hrp and hrp.Parent then hrpPos = hrp.Position else break end
                                end
                                if v.Parent == nil then
                                    if not processItem(v) then break end
                                end
                            end
                        end
                    end
                end
                
                if Settings.ChestPickupEnabled and count < totalTarget then
                    if currentTime - (Settings.LastChestScanTime or 0) > 1 then
                        Settings.LastChestScanTime = currentTime
                        task.spawn(function()
                            local newChestCache = {}
                            local deployables = workspace:FindFirstChild("Deployables")
                            if deployables then
                                for _, chest in ipairs(deployables:GetChildren()) do
                                    if (chest.Name:find("Chest") or chest.Name:find("Box")) and not chest.Name:find("Plant Box") then
                                        table.insert(newChestCache, chest)
                                    end
                                end
                            end
                            Settings.CachedChests = newChestCache
                        end)
                    end
                    
                    if Settings.CachedChests then
                        for _, chest in ipairs(Settings.CachedChests) do
                            if not chest.Parent then continue end
                            scanCount = scanCount + 1
                            if scanCount % 500 == 0 then
                                task.wait()
                                if hrp and hrp.Parent then hrpPos = hrp.Position else break end
                            end
                            if count >= totalTarget then break end
                            
                            local pos
                            if chest:IsA("PVInstance") then
                                pos = chest:GetPivot().Position
                            end
                            
                            if pos and (pos - hrpPos).Magnitude <= range then
                                local contents = chest:FindFirstChild("Contents")
                                if contents then
                                    local children = contents:GetChildren()
                                    for i = #children, 1, -1 do
                                        local item = children[i]
                                        if count >= totalTarget then break end
                                        
                                        scanCount = scanCount + 1
                                        if scanCount % 500 == 0 then
                                            task.wait()
                                            if hrp and hrp.Parent then hrpPos = hrp.Position else break end
                                        end
                                        
                                        local eid = getNetworkID(item)
                                        if eid and isItemWanted(item.Name) and not attemptedItems[item] then
                                            attemptedItems[item] = currentTime + 0.3
                                            pickupItem(eid, item.Name)
                                            count = count + 1
                                            if count % 20 == 0 then
                                                task.wait()
                                                if hrp and hrp.Parent then hrpPos = hrp.Position else break end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end)
            task.wait() -- Minimum possible yield
        end
    end)
