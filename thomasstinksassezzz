local autoEatActive = false
function startAutoEat()
    if autoEatActive then return end
    autoEatActive = true
    task.spawn(function()
        while Settings.AutoEatEnabled do
            if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                -- Get Hunger from GUI
                local mainGui = plr.PlayerGui:FindFirstChild("MainGui")
                local hungerVal = 100 -- Default safe value
                if mainGui then
                    local bars = mainGui:FindFirstChild("Panels") and mainGui.Panels:FindFirstChild("Stats") and mainGui.Panels.Stats:FindFirstChild("Bars")
                    if bars then
                        local hungerLabel = bars:FindFirstChild("Hunger") and bars.Hunger:FindFirstChild("ValueLabel")
                        if hungerLabel and hungerLabel:IsA("TextLabel") then
                            local num = tonumber(hungerLabel.Text)
                            if num then hungerVal = num end
                        end
                    end
                end

                if hungerVal <= (Settings.EatThreshold or 70) then
                     -- Use Heal settings for food and speed
                     local fruitName = Settings.HealFruit or "Bloodfruit"
                     local fruitID = resolveHealFruitItemId(fruitName)
                     
                     if fruitID and mainGui then
                         local rightPanel = mainGui:FindFirstChild("RightPanel")
                         local inventory = rightPanel and rightPanel:FindFirstChild("Inventory")
                         local list = inventory and inventory:FindFirstChild("List")
                         
                         local slotID = nil
                         if list then
                             for _, item in ipairs(list:GetChildren()) do
                                 if item:IsA("ImageLabel") and item.Name == fruitName then
                                     slotID = item.LayoutOrder
                                     break
                                 end
                             end
                         end
                         
                         if slotID then 
                             pcall(function()
                                 local pData = packetData()
                                 local actionId = pData.packets.UseBagItem
                                 local b = buffer.create(8)
                                 buffer.writeu8(b, 0, 0)
                                 buffer.writeu8(b, 1, actionId)
                                 buffer.writeu32(b, 2, slotID)
                                 buffer.writeu16(b, 6, fruitID)
                                 if ByteNetReliable then ByteNetReliable:FireServer(b) end
                             end)
                             local delayTime = 1 / (Settings.HealCPS or 1)
                             task.wait(delayTime)
                         else
                             -- Item not found in bag
                             task.wait(1)
                         end
                     else
                         task.wait(1)
                     end
                else
                     task.wait(0.5)
                end
            else
                task.wait(1)
            end
        end
        autoEatActive = false
    end)
end

-- // CONFIG SYSTEM // --
ASTER.ConfigSystem = {}
ASTER.ConfigFolder = "ASTER/Configs"

if not isfolder("ASTER") then makefolder("ASTER") end
if not isfolder(ASTER.ConfigFolder) then makefolder(ASTER.ConfigFolder) end

function ASTER.ConfigSystem.GetConfigs()
    local list = {}
    if isfolder(ASTER.ConfigFolder) then
        for _, file in ipairs(listfiles(ASTER.ConfigFolder)) do
            if file:sub(-5) == ".json" then
                table.insert(list, file:match("([^/\\]+)%.json$"))
            end
        end
    end
    return list
end

function ASTER.ConfigSystem.SaveConfig(name)
    if not name or name == "" then return end

    local function isArray(t)
        if type(t) ~= "table" then return false end
        local n = 0
        for k, _ in pairs(t) do
            if type(k) ~= "number" or k < 1 or k % 1 ~= 0 then
                return false
            end
            n += 1
        end
        for i = 1, n do
            if t[i] == nil then return false end
        end
        return true
    end

    local function escapeJsonString(s)
        return tostring(s)
            :gsub("\\", "\\\\")
            :gsub("\"", "\\\"")
            :gsub("\b", "\\b")
            :gsub("\f", "\\f")
            :gsub("\n", "\\n")
            :gsub("\r", "\\r")
            :gsub("\t", "\\t")
    end

    local function jsonEncodePrettySorted(value, indent, level)
        indent = indent or "  "
        level = level or 0
        local t = type(value)
        if t == "nil" then return "null" end
        if t == "number" then return tostring(value) end
        if t == "boolean" then return value and "true" or "false" end
        if t == "string" then return "\"" .. escapeJsonString(value) .. "\"" end
        if t ~= "table" then
            return "\"<non-serializable:" .. escapeJsonString(t) .. ">\""
        end

        local pad = string.rep(indent, level)
        local nextPad = string.rep(indent, level + 1)

        if isArray(value) then
            if #value == 0 then return "[]" end
            local parts = {}
            for i = 1, #value do
                parts[i] = nextPad .. jsonEncodePrettySorted(value[i], indent, level + 1)
            end
            return "[\n" .. table.concat(parts, ",\n") .. "\n" .. pad .. "]"
        end

        local keys = {}
        for k, _ in pairs(value) do
            table.insert(keys, k)
        end
        table.sort(keys, function(a, b) return tostring(a) < tostring(b) end)

        if #keys == 0 then return "{}" end
        local parts = {}
        for i, k in ipairs(keys) do
            local keyStr = "\"" .. escapeJsonString(tostring(k)) .. "\""
            parts[i] = nextPad .. keyStr .. ": " .. jsonEncodePrettySorted(value[k], indent, level + 1)
        end
        return "{\n" .. table.concat(parts, ",\n") .. "\n" .. pad .. "}"
    end

    local data = {}
    local count = 0
    for key, reg in pairs(Window.ElementRegistry) do
        if reg.GetValue then
            data[key] = reg.GetValue()
            count = count + 1
        end
    end

    -- Persist all "enabled" (boolean true) Settings flags, even if they aren't in ElementRegistry.
    -- This avoids JSON issues with non-serializable Settings entries (e.g., Color3 in ESPColors).
    data.EnabledSettings = {}
    for k, v in pairs(Settings) do
        if type(v) == "boolean" and v == true then
            table.insert(data.EnabledSettings, k)
        end
    end
    table.sort(data.EnabledSettings, function(a, b) return tostring(a) < tostring(b) end)

    data.MobileButtonPositions = {}
    for name, frame in pairs(Window.MobileButtons) do
        data.MobileButtonPositions[name] = {
            X = { Scale = frame.Position.X.Scale, Offset = frame.Position.X.Offset },
            Y = { Scale = frame.Position.Y.Scale, Offset = frame.Position.Y.Offset },
        }
    end

    local json = jsonEncodePrettySorted(data)
    writefile(ASTER.ConfigFolder .. "/" .. name .. ".json", json)
end

function ASTER.ConfigSystem.LoadConfig(name)
    if not name or name == "" or name == "None" then 

        return 
    end
    local path = ASTER.ConfigFolder .. "/" .. name .. ".json"
    if not isfile(path) then 

        return 
    end
    
    local success, data = pcall(function() return httpservice:JSONDecode(readfile(path)) end)
    if success and data then
        ASTER.ConfigSystem.Loading = true
        local loaded = 0
        for key, value in pairs(data) do
