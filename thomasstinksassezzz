                                shouldExpand = false
                            end

                            if shouldExpand then
                                -- Fix Floating GUIs by parenting them to Head (which doesn't resize)
                                local head = player.Character:FindFirstChild("Head")
                                if head then
                                    local function fixAdornee(parent)
                                        for _, v in ipairs(parent:GetChildren()) do
                                            if v:IsA("BillboardGui") and v.Adornee ~= head then
                                                v.Adornee = head
                                            end
                                        end
