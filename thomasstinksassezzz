                         end

                         if isGod then
                             currentTargets[item] = "Item"
                             if not highlights[item] then
                                 local adorn = item
                                 if item:IsA("Model") then adorn = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart") end
                                 
                                 if adorn then
                                     local h = Instance.new("Highlight")
                                     h.FillColor = Color3.fromRGB(255, 215, 0) -- Gold
                                     h.OutlineColor = Color3.fromRGB(255, 255, 255)
                                     h.FillTransparency = 0.3
                                     h.OutlineTransparency = 0
                                     h.Adornee = item
                                     h.Parent = item
                                     
                                     local bg = Instance.new("BillboardGui")
                                     bg.Name = "GodESP"
                                     bg.Adornee = adorn
                                     bg.Size = UDim2.new(0, 200, 0, 50)
