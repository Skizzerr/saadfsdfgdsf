        visual.Anchored = false -- Changed to false so we can weld it
        visual.CanCollide = false
        visual.CastShadow = false
        visual.Massless = true -- Ensure it doesn't affect player physics
        visual.Parent = workspace
        
        local weld = nil
        
        local function findNetworkID(object)
             for name, value in pairs(object:GetAttributes()) do
                 if typeof(value) == "number" and value > 1000 then return value end
             end
             local val = object:FindFirstChildWhichIsA("IntValue", true) or object:FindFirstChildWhichIsA("NumberValue", true)
             if val and val.Value > 1000 then return val.Value end
             return nil
        end
        

        local animTrack = nil
        local lastAnimPlay = 0
        local lastHitPlay = 0
        local lastChar = nil
        
        -- Track manual clicks with a short-lived lock (Boolean State)
        -- Prevents timestamp desync and deadlocks
        local manualAttackLock = false
        task.spawn(function()
            local UserInputService = game:GetService("UserInputService")
            UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if not gameProcessed and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
                    manualAttackLock = true
                    -- Release lock shortly after click animation would start (0.2s)
                    task.delay(0.2, function()
                        manualAttackLock = false
                    end)
                end
            end)
        end)

        local function queueTargets(eids)
            local count = #eids
            if count == 0 or not ByteNetReliable then return end

            -- 1. DEFINE EXCLUSION LIST (Keywords to ignore)
            local excludedKeywords = {"Bow", "Potion", "Sling", "Saddle", "Fishing Rod", "Horn", "Shovel"}

            -- 2. CHECK EQUIPPED TOOL IN WORKSPACE FOLDER
            local function isHoldingExcludedTool()
                local playersFolder = workspace:FindFirstChild("Players")
                local plrFolder = playersFolder and playersFolder:FindFirstChild(plr.Name)
                local toolsFolder = plrFolder and plrFolder:FindFirstChild("Tools")

                -- If no tools folder or nothing inside, we aren't holding anything to hit with
                if not toolsFolder or #toolsFolder:GetChildren() == 0 then
                    return true -- Aura should not hit if nothing is equipped
                end

                local currentTool = toolsFolder:GetChildren()[1] -- The item you are holding
                if currentTool then
                    local toolName = currentTool.Name:lower()
                    for _, keyword in ipairs(excludedKeywords) do
                        if string.find(toolName, keyword:lower(), 1, true) then
                            return true -- Tool name contains an excluded word (e.g. "Steel Bow" contains "Bow")
                        end
                    end
                end
                return false
            end

            -- If we are holding an excluded tool, stop the Aura from hitting
            if isHoldingExcludedTool() then return end

            local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            if not ByteNetReliable then return end

            local maxPackets = 4
            local hitsPerTarget = math.max(1, math.floor(maxPackets / #eids))
            local timeOffset = 0.01
            local baseTime = time() - (#eids * hitsPerTarget * timeOffset)
            
            local swingIdx = 0
            for i, eid in ipairs(eids) do
                for j = 1, hitsPerTarget do
                    swingIdx = swingIdx + 1
                    local b = buffer.create(4 + 4 + 19 + 8)
                    buffer.writeu8(b, 0, 0)
                    buffer.writeu8(b, 1, packetData().packets.SwingTool)
                    buffer.writeu16(b, 2, 1) -- Force count to 1
                    buffer.writeu32(b, 4, eid)
                    writeByteNetCFrame(b, 8, hrp.CFrame)
                    buffer.writef64(b, 27, baseTime + (swingIdx * timeOffset))
                    
                    ByteNetReliable:FireServer(b)
                end
            end

            -- 4. Send the ClientSwing Packet for Server Replication
            local swingBuf = buffer.create(2)
            buffer.writeu8(swingBuf, 0, 0)
            buffer.writeu8(swingBuf, 1, packetData().packets.ClientSwing)
            ByteNetReliable:FireServer(swingBuf)

            -- 5. Play Local Animation for the user (using existing variables)
            if targetAnimId and (os.clock() - lastAnimPlay > 0.4) then
                lastAnimPlay = os.clock()
                local char = plr.Character
