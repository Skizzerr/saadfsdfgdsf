function startAutoHeal()

    if healActive then return end
    healActive = true
    
    if healConnection then healConnection:Disconnect() healConnection = nil end
    if Settings.HealHeartbeat then
        local lastHeal = 0
        healConnection = game:GetService("RunService").Heartbeat:Connect(function()
            if not Settings.AutoHealEnabled then
                
                if not healRunning then
                    if healConnection then healConnection:Disconnect() healConnection = nil end
                    healActive = false
                    return
                end
                -- If healRunning is true, continue loop without GUI
            end
            if not Settings.HealHeartbeat then
                 if healConnection then healConnection:Disconnect() healConnection = nil end
                 healActive = false
                 
                 -- healRunning = false -- DO NOT reset this, let it persist? No, if we restart, we want it to be safe. 
                 -- Wait, if switching mode, we should keep state? 
                 -- For now, let's keep original behavior for mode switch:
                 healRunning = false 
                 startAutoHeal()
                 return
            end
            if healRunning and os.clock() - lastHeal >= (1 / Settings.HealCPS) then
                executeHeal()
                lastHeal = os.clock()
            end
        end)
    else
        task.spawn(function()
            while true do
                if not Settings.AutoHealEnabled then
                    
                    if not healRunning then break end -- Stop if both are disabled
                end

                if Settings.HealHeartbeat then break end
                if healRunning then
                    executeHeal()
                end
                task.wait(1 / Settings.HealCPS)
            end
            healActive = false
            
            healRunning = false
            if Settings.AutoHealEnabled and Settings.HealHeartbeat then startAutoHeal() end
        end)
    end
end



