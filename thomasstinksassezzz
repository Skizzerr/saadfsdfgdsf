function interactStructure(structure, actionID, itemID)
    if not structure or not ByteNetReliable then return end
    
    local function getHiddenID(object)
         local exact = object:GetAttribute("NetworkId") or object:GetAttribute("networkId") or object:GetAttribute("ID") or object:GetAttribute("Id")
         if exact then return exact end
         for name, value in pairs(object:GetAttributes()) do
             if typeof(value) == "number" then return value end
         end
         local val = object:FindFirstChildWhichIsA("IntValue", true) or object:FindFirstChildWhichIsA("NumberValue", true)
         if val then return val.Value end
         local parsed = tonumber(object.Name)
         if parsed then return parsed end
         return nil
    end

    local id = getHiddenID(structure)
    if id then
         -- Generic Structure Interaction (8 bytes)
         -- [Namespace(1), ActionID(1), TargetID(4), ItemID(2)]
         local b = buffer.create(8)
         buffer.writeu8(b, 0, 0)
         buffer.writeu8(b, 1, actionID)
         buffer.writeu32(b, 2, id)
         if itemID then
            buffer.writeu16(b, 6, itemID)
         end
         ByteNetReliable:FireServer(b)
    end
end

local plantBoxLoopActive = false
function startTweenPlantBox()
    if plantBoxLoopActive then return end
    plantBoxLoopActive = true
    task.spawn(function()
        local lastRef = nil
        local lastVec = nil
        local lastDist = nil
        while Settings.TweenToPlantBox do
            local list = getPlantBoxes(1000)
            local foundTarget = false
            local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")

            if hrp and lastRef and lastVec then
                local distNow = (hrp.Position - lastVec).Magnitude
                if Settings.PlantingTweenMode == "Walk" then
                    if lastDist and distNow > lastDist + 2 then
                        plantStopMovement()
                        lastRef, lastVec, lastDist = nil, nil, nil
                    else
                        if lastDist and math.abs(distNow - lastDist) < 0.2 and distNow > 15 then
                            local hum = plr.Character:FindFirstChild("Humanoid")
                            if hum then hum.Jump = true end
                        end
                        lastDist = distNow
                    end
                    if distNow < 15 then
                        plantStopMovement()
                        -- Do not clear lastRef here so it doesn't repeatedly try to walk to the same box while waiting for Auto Plant
                    end
                else
                    lastDist = distNow
                    if distNow < 15 then
                        if hrp then
                            hrp.Velocity = Vector3.new(0,0,0)
                            hrp.RotVelocity = Vector3.new(0,0,0)
                        end
                    end
                end
            end

            for _, box in ipairs(list) do
                local eid = box.deployable:GetAttribute("EntityID")
                if not box.deployable:FindFirstChild("Seed") and (not plantedboxes[eid] or os.clock() - plantedboxes[eid] > 1) then
                    local bp = box.part or box.deployable.PrimaryPart or box.deployable:FindFirstChildWhichIsA("BasePart")
                    if bp then
                        local targetVec = getTopOfBoxTarget(bp)
                        local needMove = true
                        if lastRef == bp and lastVec and (targetVec - lastVec).Magnitude < 0.5 then
                            needMove = false
                        end

                        if needMove then
                            moveToTargetUsingGoldLogic(targetVec)
                            lastRef = bp
                            lastVec = targetVec
                            if hrp then lastDist = (hrp.Position - targetVec).Magnitude end
                        end
                        foundTarget = true
                    end
                    break -- only handle one box at a time
                end
            end

            if not foundTarget then
                if lastRef then plantStopMovement() end
                lastRef, lastVec, lastDist = nil, nil, nil
            end
            task.wait(0.3)
        end
        plantStopMovement()
        plantBoxLoopActive = false
    end)
end

