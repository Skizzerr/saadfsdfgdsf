    local function findNearestPlayer()
        local nearestPlayer, minDistance = nil, math.huge
        if not plr or not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then return nil end
        local localPlayerPos = plr.Character.HumanoidRootPart.Position
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= plr and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local distance = (localPlayerPos - p.Character.HumanoidRootPart.Position).magnitude
                if distance < minDistance then
                    minDistance = distance
                    nearestPlayer = p
                end
            end
        end
        return nearestPlayer
    end
    
