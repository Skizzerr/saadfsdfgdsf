    task.spawn(function()
        local attemptedItems = {}
        
        -- Cached filter states to avoid parsing every tick
        local lastDropString = nil
        local dropFilters = {}
        local lastCustomString = nil
        local customFilters = {}
        local hasCustomText = false
        
        while true do
            if not Settings.AutoPickupEnabled and not Settings.ChestPickupEnabled then
                pickupActive = false
                break
            end
            pcall(function()
                local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                local count = 0
                local range = 35 -- Hardcoded pickup range to 35
                local totalTarget = tonumber(Settings.PickupBatchSize) or 150
                local throttleSize = totalTarget
                local currentTime = tick()
                
                -- Cleanup old attempted items
                for item, attemptTime in pairs(attemptedItems) do
                    if currentTime > attemptTime then 
                        attemptedItems[item] = nil
                    end
                end
                
                -- Update drop filters only if changed
                local currentDropStr = Settings.DropItem or ""
                if lastDropString ~= currentDropStr then
                    lastDropString = currentDropStr
                    table.clear(dropFilters)
                    if currentDropStr ~= "" then
                        for dropWord in string.gmatch(currentDropStr, '([^,]+)') do
                            local cleanDrop = dropWord:match("^%s*(.-)%s*$"):lower()
                            if cleanDrop ~= "" then dropFilters[cleanDrop] = true end
                        end
                    end
                end
                
                -- Update custom filters only if changed
                local currentCustomStr = Settings.CustomPickupFilter or ""
                if lastCustomString ~= currentCustomStr then
                    lastCustomString = currentCustomStr
                    table.clear(customFilters)
                    hasCustomText = currentCustomStr:gsub("%s+", "") ~= ""
                    if hasCustomText then
                        for word in string.gmatch(currentCustomStr, '([^,]+)') do
                            local cleanWord = word:match("^%s*(.-)%s*$"):lower()
                            if cleanWord ~= "" then customFilters[cleanWord] = true end
                        end
                    end
                end

                local function isItemWanted(itemName)
                    if not itemName or itemName == "" then return false end
                    local name = itemName:lower()
                    
                    if hasCustomText then
                        if customFilters[name] then return true end
                        if (name == "coin" or name == "coin2" or name == "coin stack") and customFilters["coin"] then return true end
                        if (name == "essence stack" or name == "essence") and customFilters["essence"] then return true end
                        return false
                    end
                    
                    return true 
                end
                
                -- 1. Strict typing for better Luau linting 
                 local function getNetworkID(item) 
                     return item:GetAttribute("ID") or item:GetAttribute("NetworkID") or item:GetAttribute("EntityID") 
                 end 
                 
                 -- 2. Cache the packet data safely (evaluate once, store variables) 
                 local pickupPacketID = nil 
                 local data = type(packetData) == "function" and packetData() or packetData 
                 if data and data.packets then 
                     pickupPacketID = data.packets.Pickup 
                 end 
                 
                local function pickupItem(eid, itemName) 
                     -- 3. Fallback check: Fetch packet ID dynamically if it failed to load initially 
                     if not pickupPacketID then 
                         local currentData = type(packetData) == "function" and packetData() or packetData 
                         if currentData and currentData.packets then 
                             pickupPacketID = currentData.packets.Pickup 
                         end 
                     end 
                 
                     -- 4. Strict validation to prevent buffer crashes 
                     if type(eid) ~= "number" or not pickupPacketID or not ByteNetReliable then return end 
                     
                     local itemID = autoDiscoverItemID(itemName) or 0 
                     if type(itemID) ~= "number" then itemID = 0 end 
                 
                     -- 5. Construct and send the buffer 
                     local b = buffer.create(8) 
                     buffer.writeu8(b, 0, 0) 
                     buffer.writeu8(b, 1, pickupPacketID) 
                     buffer.writeu32(b, 2, eid) 
                     buffer.writeu16(b, 6, itemID) 
                     
                     ByteNetReliable:FireServer(b) 
                 end

                local hrpPos = hrp.Position
                
                -- Core scan logic for an item
                local function processItem(item)
                    if count >= totalTarget then return false end

                    local pos
                    if item:IsA("PVInstance") then
                        pos = item:GetPivot().Position
                    end
                    
                    if pos and (pos - hrpPos).Magnitude <= range then
                        local eid = getNetworkID(item)
                        if eid and isItemWanted(item.Name) and not attemptedItems[item] then
                            attemptedItems[item] = currentTime + 0.3 -- Wait 0.3s before retrying
                            pickupItem(eid, item.Name)
                            count = count + 1
                            if count % 20 == 0 then -- smaller throttle chunk for smoother execution
                                task.wait() 
                                if hrp and hrp.Parent then hrpPos = hrp.Position else return false end
                            end
                        end
                    end
                    return true
                end

                local scanCount = 0
                
                -- Scan items folder
                if Settings.AutoPickupEnabled then
                    local itemsFolder = workspace:FindFirstChild("Items") or workspace:FindFirstChild("DroppedItems")
                    if itemsFolder then
                        local children = itemsFolder:GetChildren()
                        for i = #children, 1, -1 do
                            local item = children[i]
                            scanCount = scanCount + 1
                            if scanCount % 500 == 0 then 
                                task.wait()
                                if hrp and hrp.Parent then hrpPos = hrp.Position else break end
                            end
                            if not processItem(item) then break end
                        end
                    end
                    
                    -- Process nil items efficiently
                    if count < totalTarget then
                        if currentTime - (Settings.LastNilScanTime or 0) > 2.5 then 
                            Settings.LastNilScanTime = currentTime
                            task.spawn(function()
                                local newNilCache = {}
                                local addedCount = 0
                                pcall(function()
                                    local nilInsts = getnilinstances()
