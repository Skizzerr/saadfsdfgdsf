                                healthFill.Name = "HealthFill"
                                healthFill.Parent = healthBg
                                healthFill.BackgroundColor3 = Color3.new(0,1,0)
                                healthFill.BorderSizePixel = 0
                                healthFill.Size = UDim2.new(1, 0, 1, 0)
                                
                                local uic2 = Instance.new("UICorner")
                                uic2.CornerRadius = UDim.new(1, 0)
                                uic2.Parent = healthFill
                                 
                                 bg.Parent = char
                                 
                                 highlights[char] = {h = h, bg = bg, text = text, adorn = char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart, healthBill = healthBill, healthFill = healthFill}
                             end
                         end
                     end
                 end
                 
                 -- Update distances and cleanup
                 for target, data in pairs(highlights) do
                     if not currentTargets[target] or not target.Parent then
                         if data.h then data.h:Destroy() end
                         if data.bg then data.bg:Destroy() end
                         if data.healthBill then data.healthBill:Destroy() end
                         highlights[target] = nil
                     else
                         -- Settings
                         local showHighlight = Settings.GodESP_ShowHighlight
                         if showHighlight == nil then showHighlight = true end

                         local showNames = Settings.GodESP_ShowNames
                         if showNames == nil then showNames = true end

                         local showDist = Settings.GodESP_ShowDistance
                         local showHealth = Settings.GodESP_ShowHealth
                         if showHealth == nil then showHealth = true end

                         -- Dynamic Color Update
                         local col = Settings.ESPColors["GodESP"] or Color3.fromRGB(255, 255, 0)
                         
                         if data.h then 
                             data.h.FillColor = col 
                             data.h.OutlineColor = col
                             data.h.Enabled = showHighlight
                         end
                         
                         if data.bg then
                             data.bg.Enabled = (showNames or showDist)
                             if data.text then 
                                 data.text.TextColor3 = col
                                 local s = data.text:FindFirstChild("UIStroke")
                                 if s then s.Color = Color3.new(0,0,0) end
                                 
                                 if data.adorn then
                                    local dist = (data.adorn.Position - hrp.Position).Magnitude
                                    local label = ""
                                    if currentTargets[target] == "Player" then
                                        label = "GOD PLAYER"
                                        if target:IsA("Model") then label = "GOD: " .. target.Name end
                                    else
                                        label = "GOD ITEM"
                                    end
                                    
                                    local finalText = ""
                                    if showNames then
                                        finalText = label
                                    end
                                    
                                    if showDist then 
                                        if finalText ~= "" then finalText = finalText .. " " end
                                        finalText = finalText .. string.format("[%d]", dist) 
                                    end

                                    if Settings.GodESP_ShowArmor and currentTargets[target] == "Player" then
                                        local armorCount = 0
                                        local totalArmor = 3
                                        if target:FindFirstChild("God Halo") then
                                            armorCount = armorCount + 1
                                        end
                                        if target:FindFirstChild("God Chestplate") then
                                            armorCount = armorCount + 1
                                        end
                                        if target:FindFirstChild("God Legs") then
                                            armorCount = armorCount + 1
                                        end
                                        if finalText ~= "" then finalText = finalText .. " " end
                                        finalText = finalText .. string.format("[%d/%d]", armorCount, totalArmor)
                                    end
                                    
                                    data.text.Text = finalText
                                 end
                             end
                         end
                         
                         if data.healthBill and currentTargets[target] == "Player" then
                            data.healthBill.Enabled = showHealth
                            if showHealth and target:FindFirstChild("Humanoid") then
                                local hum = target.Humanoid
                                local health = hum.Health
                                local maxHealth = hum.MaxHealth
                                local percent = math.clamp(health / maxHealth, 0, 1)
                                if data.healthFill then
                                    data.healthFill.Size = UDim2.new(percent, 0, 1, 0)
                                    data.healthFill.BackgroundColor3 = Color3.fromHSV(percent * 0.3, 1, 1) -- Green to Red
                                end
                            end
                        end
                     end
                 end
            end
            task.wait(0.1)
        end
        
        for _, data in pairs(highlights) do
            if data.h then data.h:Destroy() end
            if data.bg then data.bg:Destroy() end
            if data.healthBill then data.healthBill:Destroy() end
        end
        godESPActive = false
    end)
end
end

