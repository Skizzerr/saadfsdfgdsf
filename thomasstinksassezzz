function startBigChestEngine()
    if chestEngineActive then return end
    if not Settings.BigChests then return end
    chestEngineActive = true
    local lastChest = nil
    local lastSize = nil
    local highlight = nil
    local goldConnection = nil
    
    local function resetLastChest()
        if lastChest and lastChest.Parent then
            local hb = lastChest:FindFirstChild("Hitbox") or lastChest:FindFirstChild("default")
            if hb then
                if lastSize and lastSize.X < 500 then 
                    hb.Size = lastSize 
                else 
                    hb.Size = Vector3.new(4, 4, 4) 
                end
                hb.Transparency = 1
                hb.CastShadow = false
            end
        end
    end

    -- Teleport Helper Function (Uses Parenting + CFrame)
    local function teleportItemToChest(item, chest)
        if not chest or not chest:FindFirstChild("Contents") then return end
        
        local itemID = item:GetAttribute("ID")
        local isGold = (item.Name == "Gold" or item.Name == "Raw Gold")
        local isEssence = (item.Name:find("Essence") ~= nil)

        if (Settings.TeleportGoldToChest and isGold) or (Settings.TeleportEssenceToChest and isEssence) then
            -- Physics initialization wait skipped in loop for speed, checked in ChildAdded
            local root = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
            if root then
                local targetPart = chest:FindFirstChild("Hitbox")
                local targetCFrame = targetPart and targetPart.CFrame or chest:GetPivot()
                
                -- Teleport precisely to the center of the chest hitbox
                root.CFrame = targetCFrame
                -- Zero out any wild rotations to prevent physics rejection
                root.AssemblyAngularVelocity = Vector3.zero
                -- Apply slight downward velocity to force physics update and replication
                root.AssemblyLinearVelocity = Vector3.new(0, -2, 0)
                
                -- Anti-Desync: Ensure the server registers the movement
                -- If we still don't have NetworkOwnership immediately, the position change won't replicate.
                -- We spawn a thread to enforce the position for a few frames until the item is destroyed (absorbed).
                task.spawn(function()
                    local retries = 0
                    while item and item.Parent == workspace.Items and retries < 10 do
                        if root then
                            root.CFrame = targetCFrame
                            root.AssemblyAngularVelocity = Vector3.zero
                            root.AssemblyLinearVelocity = Vector3.new(0, -2, 0)
                        end
                        retries = retries + 1
                        task.wait(0.1)
                    end
                end)
            end
        end
    end
    
    -- Setup Connection for New Items
