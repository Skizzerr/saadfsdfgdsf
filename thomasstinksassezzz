do
local fishActive = false

-- Helper to find packet IDs dynamically
local function getFishingPacketIDs()
    local pData = packetData()
    if not pData or not pData.packets then return 207, 211 end
    
    local castID, reelID
    for name, id in pairs(pData.packets) do
        local lower = name:lower()
        if lower == "cast" or lower == "castline" or lower == "castfishingrod" or lower == "fishcast" or lower == "rodswing" then 
            castID = id 
        end
        if lower == "reel" or lower == "reelline" or lower == "reelfishingrod" or lower == "fishreel" or lower == "rodend" then 
            reelID = id 
        end
    end
    
    -- Fallback partial match
    if not castID then
        for name, id in pairs(pData.packets) do
            local lower = name:lower()
            if lower:find("cast") and not lower:find("broadcast") and not lower:find("spell") then
                castID = id
            end
        end
    end
    if not reelID then
        for name, id in pairs(pData.packets) do
            local lower = name:lower()
            if lower:find("reel") then
                reelID = id
            end
        end
    end
    
    return castID or 207, reelID or 211
end

