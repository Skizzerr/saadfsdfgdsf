                    local recipeId = resolveGodToolCraftId(toolName)
                    local craftPkt = getPacketId("CraftItem")
                    if not recipeId or not craftPkt or not ByteNetReliable then return false end
                    local b = buffer.create(4)
                    buffer.writeu8(b, 0, 0)
                    buffer.writeu8(b, 1, craftPkt)
                    buffer.writeu16(b, 2, recipeId)
                    ByteNetReliable:FireServer(b)
                    return true
                end

                local function tryStockAndCraftGodTool(toolName)
                    -- Prefer Module IDs to avoid any UI/inventory scanning.
                    local function getItemIdFast(itemName)
                        local id = craftNameToID and craftNameToID[itemName]
                        if type(id) == "number" and id > 0 then return id end
                        if type(id) == "string" then
                            local n = tonumber(id)
                            if n and n > 0 then return n end
                        end

                        local ok, ItemIDS = pcall(function()
                            local rs = game:GetService("ReplicatedStorage")
                            local Modules = rs:FindFirstChild("Modules")
                            local m = Modules and Modules:FindFirstChild("ItemIDS")
                            return m and require(m) or nil
                        end)
                        if ok and type(ItemIDS) == "table" then
                            local mid = ItemIDS[itemName]
                            if type(mid) == "number" and mid > 0 then return mid end
                        end

                        return nil
                    end

                    local goldID = getItemIdFast("Gold")
                    if goldID and ByteNetReliable and packetData and packetData().packets.PurchaseFromShop then
                        for i = 1, 12 do
                            local b = buffer.create(8)
                            buffer.writeu8(b, 0, 0)
                            buffer.writeu8(b, 1, packetData().packets.PurchaseFromShop)
                            buffer.writeu32(b, 2, goldID)
                            buffer.writeu16(b, 6, 1)
                            ByteNetReliable:FireServer(b)
                            if i % 5 == 0 then task.wait(0.05) end
                        end
                    end
                    task.wait(0.5)
                    local crystalID = getItemIdFast("Crystal Chunk")
                    if crystalID and ByteNetReliable and packetData and packetData().packets.PurchaseFromShop then
                        for i = 1, 3 do
                            local b = buffer.create(8)
                            buffer.writeu8(b, 0, 0)
                            buffer.writeu8(b, 1, packetData().packets.PurchaseFromShop)
                            buffer.writeu32(b, 2, crystalID)
                            buffer.writeu16(b, 6, 1)
                            ByteNetReliable:FireServer(b)
                            task.wait(0.05)
                        end
                    end
                    task.wait(0.85)
                    fireGodToolCraftFor(toolName)
                end

                local function tryPickupItemInRangeForCraftMats(itemsFolder, range)
                    local pl = Players.LocalPlayer
                    local hrp = pl.Character and pl.Character:FindFirstChild("HumanoidRootPart")
                    if not hrp or not itemsFolder or not ByteNetReliable then return 0 end
                    local pData = type(packetData) == "function" and packetData() or packetData
                    local pickupPid = pData and pData.packets and pData.packets.Pickup
                    if not pickupPid then return 0 end
                    local hrpPos = hrp.Position
                    local sent = 0
                    for _, item in ipairs(itemsFolder:GetDescendants()) do
                        if item:IsA("Model") or item:IsA("BasePart") then
                            local okPos, itemPos = pcall(function() return item:GetPivot().Position end)
                            if okPos and itemPos and (hrpPos - itemPos).Magnitude <= range then
                                local eid = item:GetAttribute("ID") or item:GetAttribute("NetworkID") or item:GetAttribute("EntityID")
                                if type(eid) == "string" then eid = tonumber(eid) end
                                if not eid then
                                    local val = item:FindFirstChildWhichIsA("IntValue", true) or item:FindFirstChildWhichIsA("NumberValue", true)
                                    if val and type(val.Value) == "number" and val.Value ~= 0 then eid = val.Value end
                                end
                                if not eid then
                                    for attrName, val in pairs(item:GetAttributes()) do
                                        if typeof(val) == "number" and val ~= 0 and (attrName == "ID" or attrName == "NetworkID" or attrName == "EntityID" or attrName == "Eid" or attrName == "EntityId") then
                                            eid = val
                                            break
                                        end
                                    end
                                end
                                if not eid and item.Parent and item.Parent ~= workspace and item.Parent ~= itemsFolder then
                                    local p = item.Parent
                                    eid = p:GetAttribute("ID") or p:GetAttribute("NetworkID") or p:GetAttribute("EntityID")
                                    if type(eid) == "string" then eid = tonumber(eid) end
                                end
                                if type(eid) == "number" and eid ~= 0 then
                                    local itemID = 0
                                    if craftNameToID and craftNameToID[item.Name] then
                                        itemID = craftNameToID[item.Name]
                                    end
                                    if (itemID == 0 or not itemID) and autoDiscoverItemID then
                                        itemID = autoDiscoverItemID(item.Name) or 0
                                    end
                                    if type(itemID) ~= "number" then itemID = 0 end
                                    local b = buffer.create(8)
                                    buffer.writeu8(b, 0, 0)
                                    buffer.writeu8(b, 1, pickupPid)
                                    buffer.writeu32(b, 2, eid)
                                    buffer.writeu16(b, 6, itemID)
                                    ByteNetReliable:FireServer(b)
                                    sent = sent + 1
                                    if sent >= 220 then break end
                                end
                            end
                        end
                    end
                    return sent
                end

                local farmGodToolObtainAttempted = false

                while Settings.StartFarmChoiceEnabled do
                    local treeFound = false
                    local essenceFound = false
                    local treeObj = nil
                    
                    local player = Players.LocalPlayer
                    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    
                    local targetName = Settings.FarmChoice or "Ancient Tree"
                    local axeName = Settings.FarmTool or "Void Axe"
                    if targetName ~= "Ancient Tree" then
                        axeName = "God Pick"
                    end

                    if (axeName == "God Axe" or axeName == "God Pick") and not hasFarmTool(axeName) and not farmGodToolObtainAttempted then
                        farmGodToolObtainAttempted = true
                        local obtainOpt = Settings.ToolSaveOption or "BuyFromShop (GodOnly)"
                        if obtainOpt == "Reset&Loot" then
                            local char = Players.LocalPlayer.Character
                            if char and char:FindFirstChild("Humanoid") then
                                char.Humanoid.Health = 0
                            end
                            task.wait(0.8)
                            if ByteNetReliable and packetData and packetData().packets.Rebirth then
                                local b = buffer.create(2)
                                buffer.writeu8(b, 0, 0)
                                buffer.writeu8(b, 1, packetData().packets.Rebirth)
                                ByteNetReliable:FireServer(b)
                            end
                            -- Reset&Loot: do not run any heavy item scanning on start.
                            task.wait(4)
                        else
                            tryStockAndCraftGodTool(axeName)
                        end
                    end
                    
                    -- Mobile/Android Optimization: Find the boss instantly without looping the whole game
                    treeObj = workspace:FindFirstChild(targetName, true)
                    if treeObj then
                        treeFound = true
                    end
                    
                    -- Essence sits as a direct child of workspace.Items (e.g. Items:GetChildren()[n]); also allow renames / nested parts.
                    if targetName == "Ancient Tree" then
                        local itemsFolder = workspace:FindFirstChild("Items") or workspace:FindFirstChild("DroppedItems") or workspace
                        local function worldNameIsEssenceDrop(name)
                            if not name or name == "" then return false end
                            local n = string.lower(name)
                            return n == "essence" or n == "essence stack" or string.find(n, "essence", 1, true) ~= nil
                        end
                        local seenPickupEid = {}
                        local function coerceEntityId(v)
                            if type(v) == "number" and v == v and v ~= 0 then return v end
                            if type(v) == "string" then
                                local n = tonumber(v)
                                if type(n) == "number" and n ~= 0 then return n end
                            end
                            return nil
                        end
                        local function readEntityIdOnInstance(inst)
                            if not inst then return nil end
                            return coerceEntityId(inst:GetAttribute("ID"))
                                or coerceEntityId(inst:GetAttribute("NetworkID"))
                                or coerceEntityId(inst:GetAttribute("EntityID"))
                                or coerceEntityId(inst:GetAttribute("Eid"))
                                or coerceEntityId(inst:GetAttribute("EntityId"))
                        end
                        local function readEntityIdFromSubtree(root)
                            local eid = readEntityIdOnInstance(root)
                            if eid then return eid end
                            for _, childName in ipairs({ "ID", "NetworkID", "EntityID", "Eid", "EntityId" }) do
                                local ch = root:FindFirstChild(childName, true)
                                if ch and (ch:IsA("IntValue") or ch:IsA("NumberValue")) then
                                    eid = coerceEntityId(ch.Value)
                                    if eid then return eid end
                                end
                            end
                            for _, d in ipairs(root:GetDescendants()) do
                                eid = readEntityIdOnInstance(d)
                                if eid then return eid end
                            end
                            return nil
                        end
                        local function tryPickupEssenceObj(obj)
                            if not worldNameIsEssenceDrop(obj.Name) then return end
                            if hrp then
                                local ok, pos = pcall(function()
                                    return obj:GetPivot().Position
                                end)
                                if ok and pos and (pos - hrp.Position).Magnitude > 150 then return end
                            end
                            essenceFound = true
                            local eid = readEntityIdFromSubtree(obj)
                            if not eid and obj.Parent and obj.Parent ~= itemsFolder and obj.Parent ~= workspace then
                                eid = readEntityIdFromSubtree(obj.Parent)
                            end
                            if not eid or seenPickupEid[eid] then return end
                            seenPickupEid[eid] = true
                            local itemID = 0
                            if autoDiscoverItemID then
                                itemID = autoDiscoverItemID(obj.Name) or autoDiscoverItemID("Essence") or autoDiscoverItemID("Essence Stack") or 0
                            end
                            if type(itemID) ~= "number" then itemID = 0 end
                            if ByteNetReliable and packetData and packetData().packets.Pickup and type(eid) == "number" then
                                local b = buffer.create(8)
                                buffer.writeu8(b, 0, 0)
                                buffer.writeu8(b, 1, packetData().packets.Pickup)
                                buffer.writeu32(b, 2, eid)
                                buffer.writeu16(b, 6, itemID)
                                ByteNetReliable:FireServer(b)
                            end
                        end
                        if itemsFolder.Name == "Items" or itemsFolder.Name == "DroppedItems" then
                            for _, obj in ipairs(itemsFolder:GetChildren()) do
                                tryPickupEssenceObj(obj)
                            end
                            for _, obj in ipairs(itemsFolder:GetDescendants()) do
                                tryPickupEssenceObj(obj)
                            end
                        else
                            for _, obj in ipairs(itemsFolder:GetDescendants()) do
                                tryPickupEssenceObj(obj)
                            end
                        end
                    end

                    if treeObj then
                        if not isToolEquipped(axeName) then
                            equipItemPacket(axeName)
                            task.wait(0.2)
                        end
                        
                        if hrp and ByteNetReliable and packetData and packetData().packets.SwingTool then
                            
                            local eid = treeObj:GetAttribute("NetworkID") or treeObj:GetAttribute("EntityID") or treeObj:GetAttribute("ID")
                            if not eid then
                                local valObj = treeObj:FindFirstChildWhichIsA("IntValue", true) or treeObj:FindFirstChildWhichIsA("NumberValue", true)
                                if valObj and valObj.Value > 1000 then eid = valObj.Value end
                            end
                            if not eid then
                                for name, val in pairs(treeObj:GetAttributes()) do
                                    if typeof(val) == "number" and val > 1000 then eid = val break end
                                end
                            end
                            
                            if eid then
                                local maxPackets = 4
                                local timeOffset = 0.01
                                local baseTime = time() - (maxPackets * timeOffset)
                                for i = 1, maxPackets do
                                    local b = buffer.create(4 + 4 + 19 + 8)
                                    buffer.writeu8(b, 0, 0)
                                    buffer.writeu8(b, 1, packetData().packets.SwingTool)
                                    buffer.writeu16(b, 2, 1) 
                                    buffer.writeu32(b, 4, eid)
                                    if writeByteNetCFrame then writeByteNetCFrame(b, 8, hrp.CFrame) end
                                    buffer.writef64(b, 27, baseTime + (i * timeOffset))
                                    ByteNetReliable:FireServer(b)
                                end
                                
                                local swingBuf = buffer.create(2)
                                buffer.writeu8(swingBuf, 0, 0)
                                buffer.writeu8(swingBuf, 1, packetData().packets.ClientSwing)
                                ByteNetReliable:FireServer(swingBuf)
                            end
                        end
                    end
                    
                    if not treeFound and not essenceFound then
                        local player = Players.LocalPlayer
                        local topbarGui = player:WaitForChild("PlayerGui", 5) and player.PlayerGui:FindFirstChild("Topbar")
                        local levelLabel = topbarGui and topbarGui:FindFirstChild("Topbar") and topbarGui.Topbar:FindFirstChild("Right") and topbarGui.Topbar.Right:FindFirstChild("Level") and topbarGui.Topbar.Right.Level:FindFirstChild("Level")
                        local rawText = levelLabel and levelLabel.Text or "0"
                        local levelNumber = tonumber(rawText:match("%d+")) or 0
                        
                        if targetName ~= "Ancient Tree" and Settings.GodLootPickUpEnabled then
                            -- God Loot Pickup Sequence
                            local pickupStart = tick()
                            while tick() - pickupStart < 4 do
                                local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                if hrp and ByteNetReliable and packetData and packetData().packets.Pickup then
                                    local itemsFolder = workspace:FindFirstChild("Items") or workspace:FindFirstChild("DroppedItems") or workspace
                                    for _, item in ipairs(itemsFolder:GetDescendants()) do
                                        if item:IsA("Model") or item:IsA("BasePart") then
                                            local itemPos = item:GetPivot().Position
                                            if (hrp.Position - itemPos).Magnitude < 40 then
                                                local eid = item:GetAttribute("NetworkID") or item:GetAttribute("EntityID") or item:GetAttribute("ID")
                                                if not eid then
                                                    local val = item:FindFirstChildWhichIsA("IntValue", true) or item:FindFirstChildWhichIsA("NumberValue", true)
                                                    if val and val.Value > 1000 then eid = val.Value end
                                                end
                                                if not eid then
                                                    for name, val in pairs(item:GetAttributes()) do
                                                        if typeof(val) == "number" and val > 1000 then eid = val break end
                                                    end
                                                end
                                                
                                                local itemID = autoDiscoverItemID and autoDiscoverItemID(item.Name)
                                                if itemID and eid then
                                                    local b = buffer.create(8)
                                                    buffer.writeu8(b, 0, 0)
                                                    buffer.writeu8(b, 1, packetData().packets.Pickup)
                                                    buffer.writeu32(b, 2, eid)
                                                    buffer.writeu16(b, 6, itemID)
                                                    ByteNetReliable:FireServer(b)
                                                end
                                            end
                                        end
                                    end
                                end
                                task.wait(0.05)
                            end
                        end
                        
                        if levelNumber >= 100 and (targetName == "Ancient Tree" or Settings.GodAutoRebirthEnabled) then
                            if axeName ~= "God Axe" and axeName ~= "God Pick" then
                                local slot = getToolSlot(axeName)
                                if slot then
                                    local b = buffer.create(3)
                                    buffer.writeu8(b, 0, 0)
                                    buffer.writeu8(b, 1, packetData().packets.Retool or 86)
                                    buffer.writeu8(b, 2, slot)
                                    
                                    if ByteNetReliable then
                                        ByteNetReliable:FireServer(b)
                                    end
                                    
                                    task.wait(0.3) -- Give the server time to process the Retool before dropping
                                    if drop then drop(axeName) end
                                    task.wait(0.5)
                                end
                                
                                -- Rebirth
                                if ByteNetReliable and packetData and packetData().packets.Rebirth then
                                    local b = buffer.create(2)
                                    buffer.writeu8(b, 0, 0)
                                    buffer.writeu8(b, 1, packetData().packets.Rebirth)
                                    ByteNetReliable:FireServer(b)
                                end
                                task.wait(2.5) -- Wait for bed respawn
                                
                                -- Pick up the dropped axe repeatedly until we have it
                                local itemsFolder = workspace:FindFirstChild("Items") or workspace:FindFirstChild("DroppedItems") or workspace
                                while not hasFarmTool(axeName) do
                                    local axeItem = nil
                                    for _, item in ipairs(itemsFolder:GetDescendants()) do
                                        if item.Name == axeName then
                                            axeItem = item
                                            break
                                        end
                                    end
                                    
                                    if axeItem then
                                        local eid = axeItem:GetAttribute("NetworkID") or axeItem:GetAttribute("EntityID") or axeItem:GetAttribute("ID")
                                        if not eid then
                                            local val = axeItem:FindFirstChildWhichIsA("IntValue", true) or axeItem:FindFirstChildWhichIsA("NumberValue", true)
                                            if val and val.Value > 1000 then eid = val.Value end
                                        end
                                        if not eid then
                                            for name, val in pairs(axeItem:GetAttributes()) do
                                                if typeof(val) == "number" and val > 1000 then eid = val break end
                                            end
                                        end
                                        
                                        local itemID = (autoDiscoverItemID and autoDiscoverItemID(axeName)) or manualToolIDs[axeName]
                                        
                                        if itemID and eid and ByteNetReliable and packetData and packetData().packets.Pickup then
                                            local b = buffer.create(8)
                                            buffer.writeu8(b, 0, 0)
                                            buffer.writeu8(b, 1, packetData().packets.Pickup)
                                            buffer.writeu32(b, 2, eid)
                                            buffer.writeu16(b, 6, itemID)
                                            ByteNetReliable:FireServer(b)
                                        end
                                    end
                                    task.wait(0.2)
                                end
                            else
                                -- God Axe / God Pick Logic
                                local godAxeOption = Settings.ToolSaveOption or "BuyFromShop (GodOnly)"
                                
                                if godAxeOption == "Reset&Loot" then
                                    -- Reset character
                                    local char = Players.LocalPlayer.Character
                                    if char and char:FindFirstChild("Humanoid") then
                                        char.Humanoid.Health = 0
                                    end
                                    task.wait(0.8) -- Wait for character to die and drop bag
                                    
                                    -- Rebirth
                                    if ByteNetReliable and packetData and packetData().packets.Rebirth then
                                        local b = buffer.create(2)
                                        buffer.writeu8(b, 0, 0)
                                        buffer.writeu8(b, 1, packetData().packets.Rebirth)
                                        ByteNetReliable:FireServer(b)
                                    end
                                    
                                    task.wait(4) -- Wait longer for spawn menu to teleport
                                    -- Reset&Loot: do not scan items/craft on toggle enable. The "loot" path
                                    -- is intentionally lightweight here; farming loop will continue normally.
                                else
                                    -- BuyFromShop (GodOnly): one rebirth, one shop stock-up, one craft (no repeat buys)
                                    if ByteNetReliable and packetData and packetData().packets.Rebirth then
                                        local b = buffer.create(2)
                                        buffer.writeu8(b, 0, 0)
                                        buffer.writeu8(b, 1, packetData().packets.Rebirth)
                                        ByteNetReliable:FireServer(b)
                                    end
                                    task.wait(2.5)
                                    tryStockAndCraftGodTool(axeName)
                                    task.wait(0.9)
                                end
                            end
                            
                            task.wait(2.5)
                        end
                        
                        Settings.StartFarmChoiceEnabled = false
                        local privateServerId = workspace:GetAttribute("privateServerId") or ""
                        if privateServerId ~= "" then
                            Players.LocalPlayer:Kick("\n\nYou have been kicked from the server.\nVIP ID: " .. privateServerId)
                        else
                            Players.LocalPlayer:Kick("\n\nYou have been safely kicked from the server.")
                        end
                        
                        break
                    end
                    
                    task.wait(0.2)
                end
            end)
        end
    end)

