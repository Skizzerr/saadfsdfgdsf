getPlantBoxes = function(range)
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return {} end

    local plantBoxes = {}
    local deployables = workspace:FindFirstChild("Deployables")
    if not deployables then return {} end

    local parts = deployables:GetChildren()

    for _, model in ipairs(parts) do
        if model:IsA("Model") and model.Name == "Plant Box" then
            local part = model.PrimaryPart or model:FindFirstChild("Hitbox") or model:FindFirstChildWhichIsA("BasePart")
            if part then
                local dist = (hrp.Position - part.Position).Magnitude
                if dist <= (range or 250) then
                    table.insert(plantBoxes, {dist = dist, deployable = model, part = part})
                end
            end
        end
    end

    table.sort(plantBoxes, function(a, b) return a.dist < b.dist end)
    return plantBoxes
end

function findNearestPlantBoxNear(pos, range)
    local deployables = workspace:FindFirstChild("Deployables")
    if not deployables then return nil end
    local nearestPart = nil
    local closest = math.huge
    for _, d in ipairs(deployables:GetChildren()) do
        if d:IsA("Model") and d.Name == "Plant Box" then
            local pp = d.PrimaryPart or d:FindFirstChildWhichIsA("BasePart")
            if pp then local dist = (pp.Position - pos).Magnitude if dist <= range and dist < closest then closest = dist nearestPart = pp end end
        end
    end
    return nearestPart
end

function getTopOfBoxTarget(part)
    if not part or not part.Size then return part and part.Position or Vector3.new() end
    return part.Position + part.CFrame.UpVector * (part.Size.Y/2 + 3)
end

function getBushes(range, fruitname)
    BushesCache = BushesCache or {}
    BushesLastScan = BushesLastScan or {}
    local key = tostring(fruitname or "Bloodfruit")
    local now = tick()
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return {} end
    if not BushesCache[key] then BushesCache[key] = {} BushesLastScan[key] = 0 end
    local function rebuild()
        local list = {}
        for _, m in ipairs(workspace:GetChildren()) do
            if m:IsA("Model") and m.Name:find(key) then
                local pp = m.PrimaryPart or m:FindFirstChildWhichIsA("BasePart")
                if pp then table.insert(list, {model = m, part = pp}) end
            end
        end
        BushesCache[key] = list
        BushesLastScan[key] = now
    end
    if now - (BushesLastScan[key] or 0) > 0.5 then rebuild() end
    local maxRange = range or (Settings.TweenRange or 250)
    local result = {}
    for _, entry in ipairs(BushesCache[key]) do
        if entry.model and entry.model.Parent and entry.part and entry.part.Parent then
            local dist = (entry.part.Position - hrp.Position).Magnitude
            if dist <= maxRange then table.insert(result, {model = entry.model, dist = dist, part = entry.part}) end
        end
    end
    table.sort(result, function(a, b) return a.dist < b.dist end)
    return result
end

