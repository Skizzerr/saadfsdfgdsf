autoPotionActive = false
function startAutoPotion()
    if autoPotionActive then return end
    autoPotionActive = true
    task.spawn(function()
        while Settings.AutoPotionEnabled do
            local cauldron = getNearestCauldron(Settings.PotionRange or 25)
            if cauldron then
                local selection = Settings.SelectedPotion or "Swiftness Potion"
                local recipe = PotionRecipes[selection]
                if recipe then
                    local leadIce = countLeadingIce(recipe)
                    if leadIce > 0 then
                        expandCauldronHitboxOnce(cauldron)
                        dropBatchFromInventory("Ice Cube", leadIce)
                        shrinkCauldronHitbox(cauldron)
                    end
                    
                    while Settings.AutoPotionEnabled do
                        local stillIce = false
                        for _, obj in pairs(cauldron:GetDescendants()) do
                            if obj.Name == "Ice Cube" then stillIce = true break end
                        end
                        if not stillIce then break end
                        task.wait(0.2)
                    end
                    
                    expandCauldronHitboxOnce(cauldron)
                    local counts = {}
                    for j = leadIce + 1, #recipe do
                        local item = recipe[j]
                        counts[item] = (counts[item] or 0) + 1
                    end
                    local processedItems = {}
                    for j = leadIce + 1, #recipe do
                        local item = recipe[j]
                        if not processedItems[item] then
                            if counts[item] and counts[item] > 0 then
                                dropBatchFromInventory(item, counts[item])
                                counts[item] = 0
                            end
                            processedItems[item] = true
                        end
                    end
                    shrinkCauldronHitbox(cauldron)
                    
                    task.wait(0.2)
                    local eID = cauldron:GetAttribute("EntityID")
                    if eID and ByteNetReliable then
                        local bottleID = autoDiscoverItemID("Glass Bottle")
                        if bottleID then
                            local b = buffer.create(8)
                            buffer.writeu8(b, 0, 0)
                            buffer.writeu8(b, 1, packetData().packets.SweepPotion)
                            buffer.writeu32(b, 2, eID)
                            buffer.writeu16(b, 6, bottleID)
                            ByteNetReliable:FireServer(b)
                        end
                    end
                    while Settings.AutoPotionEnabled do
                        local hitbox = cauldron:FindFirstChild("Hitbox")
                        local bubbles = hitbox and hitbox:FindFirstChildOfClass("ParticleEmitter")
                        local active = bubbles and bubbles.Enabled == true
                        if not active then break end
                        task.wait(0.2)
                    end
                end
            end
            task.wait(0.2)
        end
        autoPotionActive = false
    end)
end

