do
coinActive = false
function startCoinPresser()
    if coinActive then return end
    coinActive = true
    task.spawn(function()
        local cachedPress = nil
        local ItemIDS = require(game:GetService("ReplicatedStorage").Modules.ItemIDS)
        local goldID = ItemIDS["Gold"] or ItemIDS["Gold Ore"]
        
        local function getHiddenID(object)
             local exact = object:GetAttribute("NetworkId") or object:GetAttribute("networkId") or object:GetAttribute("ID") or object:GetAttribute("Id")
             if exact then return exact end
             for name, value in pairs(object:GetAttributes()) do
                 if typeof(value) == "number" then return value end
             end
             local val = object:FindFirstChildWhichIsA("IntValue", true) or object:FindFirstChildWhichIsA("NumberValue", true)
             if val then return val.Value end
             local parsed = tonumber(object.Name)
             if parsed then return parsed end
             return nil
        end
        
        -- Local helper to avoid dependency on outer getlayout
        local function getlayout(name)
             local mainGui = plr.PlayerGui:FindFirstChild("MainGui")
             local inventory = mainGui and mainGui.RightPanel and mainGui.RightPanel.Inventory and mainGui.RightPanel.Inventory.List
             if inventory and inventory:FindFirstChild(name) then return true end
             return false
        end

        while Settings.CoinPresserEnabled do
            local success = pcall(function()
                local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                
                -- Check for Gold in Inventory
                local hasGold = false
                if getlayout("Gold") then hasGold = true end

                if hasGold then
                    -- 2. Find the Coin Press nearby
                    local targetPress = nil
                    
                    if cachedPress and cachedPress.Parent and cachedPress:GetPivot() then
                        local dist = (cachedPress:GetPivot().Position - hrp.Position).Magnitude
                        if dist < 20 then
                            targetPress = cachedPress
                        else
                            cachedPress = nil
                        end
                    end
                    
                    if not targetPress then
                        local deployables = workspace:FindFirstChild("Deployables")
                        if deployables then
                            for _, obj in pairs(deployables:GetChildren()) do
                                if obj.Name:find("Press") then
                                    local dist = (obj:GetPivot().Position - hrp.Position).Magnitude
                                    if dist < 20 then
                                        targetPress = obj
                                        cachedPress = obj
                                        break
                                    end
                                end
                            end
                        end
                    end

                    if targetPress then
                        local networkID = getHiddenID(targetPress)
                        
                        if networkID and ByteNetReliable then
                            -- 4. Recreate the 8-byte buffer: [Namespace, Action(201), PressID(u32), GoldID(u16)]
                            local b = buffer.create(8)
                            buffer.writeu8(b, 0, 0)
                            buffer.writeu8(b, 1, packetData().packets.InteractStructure)        -- Action ID 201 (NOT 213)
                            buffer.writeu32(b, 2, networkID) -- Target Press Network ID
                            buffer.writeu16(b, 6, goldID)    -- Gold Item ID from ItemIDS
                            
                            ByteNetReliable:FireServer(b)
                        end
                    end
                end
            end)
            wait(0.01) -- Small delay
        end
        coinActive = false
    end)
end
