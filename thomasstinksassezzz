function getNearestCauldron(range)
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    local deployables = workspace:FindFirstChild("Deployables")
    if not hrp or not deployables then return nil end
    local nearest, minDist = nil, range or 25
    for _, v in ipairs(deployables:GetChildren()) do
        if v:IsA("Model") and (v.Name:find("Cauldron") or v.Name:find("Brew")) then
            local pos = v:GetPivot().Position
            local dist = (pos - hrp.Position).Magnitude
            if dist < minDist then
                minDist = dist
                nearest = v
            end
        end
    end
    return nearest
end

function getNearestCauldrons(count, range)
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    local deployables = workspace:FindFirstChild("Deployables")
    if not hrp or not deployables then return {} end
    local list = {}
    for _, v in ipairs(deployables:GetChildren()) do
        if v:IsA("Model") and (v.Name:find("Cauldron") or v.Name:find("Brew")) then
            local dist = (v:GetPivot().Position - hrp.Position).Magnitude
            if dist <= (range or Settings.PotionRange or 25) then
                table.insert(list, {model = v, d = dist})
            end
        end
    end
    table.sort(list, function(a, b) return a.d < b.d end)
    local out = {}
    local maxn = math.min(count or 5, #list)
    for i = 1, maxn do
        table.insert(out, list[i].model)
    end
    return out
end

function countLeadingIce(recipe)
    local n = 0
    for i = 1, #recipe do
        if recipe[i] == "Ice Cube" then
            n = n + 1
        else
            break
        end
    end
    return n
end

function getIngredientCount(cauldron, itemName)
    local count = 0
    for _, obj in ipairs(cauldron:GetDescendants()) do
        if obj.Name == itemName then
            count = count + 1
        end
