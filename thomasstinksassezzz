function updateTabVisuals(tabObj, isActive)
    if isActive then
        -- Active State: Hollow effect on, dark background
        applyHollowEffect(tabObj.Btn, 1.1, true)
        tabObj.Btn.BackgroundTransparency = GlobalTransparency
        tabObj.Btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        
        -- Remove background gradient from the button itself to keep it dark
        local bgGrad = tabObj.Btn:FindFirstChild("ThemeGradient")
        if bgGrad then bgGrad:Destroy() end
    else
        -- Inactive State: Hollow effect off, transparent background
        applyHollowEffect(tabObj.Btn, 1.1, false)
        tabObj.Btn.BackgroundTransparency = 1 
    end
    
    -- Consistency Fix: Re-apply the same gradient logic to Text and Icon
    -- This ensures the color sequence is identical for both states
    ApplyGradient(tabObj.Btn) -- Applies to the Button Text
    ApplyGradient(tabObj.Icon) -- Applies to the Icon Image
end

