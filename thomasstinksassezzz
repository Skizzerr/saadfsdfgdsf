-- Helper to extract RemoteEvent from a function (Bypasses wrapper debounce)
local function getRemoteFromFunction(func)
    if not func or type(func) ~= "function" then return nil end
    -- Check if debug library is available (Standard exploit environment)
    if debug and debug.getupvalues then
        for _, val in pairs(debug.getupvalues(func)) do
            if typeof(val) == "Instance" and val:IsA("RemoteEvent") then
                return val
            end
            -- Deep search one level
            if type(val) == "table" then
                 for _, v2 in pairs(val) do
                     if typeof(v2) == "Instance" and v2:IsA("RemoteEvent") then
                         return v2
                     end
                 end
            end
        end
    end
    return nil
end

-- Pinch: "trapped" = holding walk but horizontal speed stays ~0 (unlike AFK stand = no input).
local pinchTrappedAccum = 0

local function firePinchBurst(dt)
     dt = (typeof(dt) == "number" and dt > 0 and dt) or (1 / 60)
     -- Removed getPackets() check since we construct the packet manually now
     if not ConfigPinch.TargetPlayer or not ConfigPinch.TargetPlayer.Character then 
         return 
     end 
     
     local char = ConfigPinch.TargetPlayer.Character
     local hrp = char:FindFirstChild("HumanoidRootPart")
     local hum = char:FindFirstChild("Humanoid")
     if not hrp then return end 
 
     local velocity = hrp.AssemblyLinearVelocity
     local horizontalVelocity = Vector3.new(velocity.X, 0, velocity.Z)
     local hSpeed = horizontalVelocity.Magnitude

     if hum then
         local state = hum:GetState()
         local airOrRagdoll = state == Enum.HumanoidStateType.Freefall
             or state == Enum.HumanoidStateType.Flying
             or state == Enum.HumanoidStateType.Physics
         if not airOrRagdoll then
             local pressingMove = hum.MoveDirection.Magnitude > 0.12
             if pressingMove and hSpeed < 0.85 then
                 pinchTrappedAccum += dt
             else
                 pinchTrappedAccum = math.max(0, pinchTrappedAccum - dt * 2.5)
             end
             if pinchTrappedAccum >= 0.22 then
                 return
             end
         else
             pinchTrappedAccum = math.max(0, pinchTrappedAccum - dt * 4)
         end
     end

     local base = hrp.Position 
     
     local cf1, cf2
     
     -- Improved Prediction Logic: Pinches based on physical movement velocity
    local targetBase = base

    if horizontalVelocity.Magnitude > 2 then
        local moveDir = horizontalVelocity.Unit
        -- Shift the base position "in front" of movement path by 5 studs
        targetBase = base + (moveDir * 5)
    end
    
    -- Use Standard Offsets & Fixed Rotation relative to targetBase
    local rot = CFrame.Angles(0, math.rad(ConfigPinch.FixedRotation), 0) 
    
    local xOff = ConfigPinch.X_Offset or 0
    local zOff = ConfigPinch.Z_Offset or 0
    
    -- Ensure it places exactly at the specified X and Z offsets for both sides
    cf1 = CFrame.new(targetBase.X + xOff, targetBase.Y - 3.5, targetBase.Z + zOff) * rot 
    cf2 = CFrame.new(targetBase.X - xOff, targetBase.Y - 3.5, targetBase.Z - zOff) * rot 
    
     local sid = ConfigPinch.StructureID or autoDiscoverItemID(ConfigPinch.ItemName)
     
    -- Manual ByteNet Packet Construction
    local function sendPlacePacket(cframe, itemName, structureId)
        if not ByteNetReliable then return end
        
        -- Booga Booga Reborn Deployable Packet Format (String-based + 6 floats)
        -- Format: [0][ActionID][NameLen (u16)][Name][X (f32)][Y (f32)][Z (f32)][RotX (f32)][RotY (f32)][RotZ (f32)]
        local nameLen = #itemName
        local size = 4 + nameLen + 24 -- 1 + 1 + 2 + length + (6 * 4)
        
        local b = buffer.create(size)
        
        buffer.writeu8(b, 0, 0) -- Packet ID (Always 0 for reliability)
        buffer.writeu8(b, 1, getPlaceStructureId()) -- Action ID
        
        buffer.writeu16(b, 2, nameLen)
        for i = 1, nameLen do
            buffer.writeu8(b, 3 + i, string.byte(itemName, i))
        end
        
        local offset = 4 + nameLen
        
        -- Decompose CFrame into Position and Euler Angles (X, Y, Z, RotX, RotY, RotZ)
        local rx, ry, rz = cframe:ToEulerAnglesXYZ()
        
        buffer.writef32(b, offset, cframe.Position.X)
        buffer.writef32(b, offset + 4, cframe.Position.Y)
        buffer.writef32(b, offset + 8, cframe.Position.Z)
        buffer.writef32(b, offset + 12, rx)
        buffer.writef32(b, offset + 16, ry)
        buffer.writef32(b, offset + 20, rz)
        
        ByteNetReliable:FireServer(b)
    end
    
    -- FIRE BOTH IMMEDIATELY - Sequential calls allow packet bundling
    sendPlacePacket(cf1, ConfigPinch.ItemName or "Wood Gate", sid)
    sendPlacePacket(cf2, ConfigPinch.ItemName or "Wood Gate", sid)
     
     ConfigPinch.LastTrap = tick() 
end 

-- Main Pinch Loop
game:GetService("RunService").Heartbeat:Connect(function(dt)
     if ConfigPinch.Enabled and ConfigPinch.TargetPlayer and tick() - ConfigPinch.LastTrap > 0.01 then 
         firePinchBurst(dt) 
     end 
end)

local resourceActive = false
local goldNodeCache = {}
local lastGoldScan = 0

-- [[ OPTIMIZATION: Resource ID Cache ]] --
local ResourceIDCache = setmetatable({}, {__mode = "k"})

function startResourceAura()
    if resourceActive then return end
    resourceActive = true

    -- [[ OPTIMIZATION: Unified Caching & Scanning ]] --
    local resourceCache = {}
    local lastFullScan = 0

    local function getResourceID(model)
        if not model or not model:IsA("Model") then return nil end
        if ResourceIDCache[model] then return ResourceIDCache[model] end
        
        local eid = model:GetAttribute("EntityID") or model:GetAttribute("ID")
        if not eid then
             for name, value in pairs(model:GetAttributes()) do
                 if typeof(value) == "number" and value > 1000 then eid = value break end
             end
        end
        if not eid then
             local val = model:FindFirstChildWhichIsA("IntValue", true) or model:FindFirstChildWhichIsA("NumberValue", true)
             if val and val.Value > 1000 then eid = val.Value end
        end
        
        if eid then ResourceIDCache[model] = eid end
        return eid
    end

    local function hitTargets(targetData)
        if #targetData == 0 then return end
        local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        if not ByteNetReliable then return end

        -- Reliable: count=1 packets, but aim at the resource so facing doesn't matter.
        -- When tweening (fast client motion), lead the origin slightly using velocity
        -- so server-side distance checks are more likely to pass.
        local vel = hrp.AssemblyLinearVelocity or Vector3.zero
        local horizontalVel = Vector3.new(vel.X, 0, vel.Z)
        local tweening = (isTweening == true) or (horizontalVel.Magnitude > 18)
        local leadTime = tweening and 0.12 or 0
        local fromPos = hrp.Position + (horizontalVel * leadTime)

        local maxPackets = 4
        local hitsPerTarget = math.max(1, math.floor(maxPackets / #targetData))
        local timeOffset = 0.01
        local baseTime = time() - (#targetData * hitsPerTarget * timeOffset)
        
        local swingIdx = 0
        for i, t in ipairs(targetData) do
            local targetPos = t and t.pos
            local attackCFrame = hrp.CFrame
            if typeof(targetPos) == "Vector3" and (targetPos - fromPos).Magnitude > 0.01 then
                attackCFrame = CFrame.lookAt(fromPos, targetPos)
            end
            for j = 1, hitsPerTarget do
                swingIdx = swingIdx + 1
                local b = buffer.create(4 + 4 + 19 + 8)
                buffer.writeu8(b, 0, 0)
                buffer.writeu8(b, 1, packetData().packets.SwingTool)
                buffer.writeu16(b, 2, 1) -- Keep count as 1 to avoid server-side array rejections
                buffer.writeu32(b, 4, t.eid)
                writeByteNetCFrame(b, 8, attackCFrame)
                buffer.writef64(b, 27, baseTime + (swingIdx * timeOffset))
                ByteNetReliable:FireServer(b)
            end
        end
    end

    task.spawn(function()
        while Settings.ResourceAuraEnabled do
            pcall(function()
                local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                local now = tick()
                -- Rescan resources periodically (workspace.Resources only)
                if now - lastFullScan > 4 then
                    lastFullScan = now
                    table.clear(resourceCache)
                    
                    local foldersToScan = {}
                    if workspace:FindFirstChild("Resources") then table.insert(foldersToScan, workspace.Resources) end
                    
                    for _, folder in ipairs(foldersToScan) do
                        for _, item in ipairs(folder:GetDescendants()) do
                            if item:IsA("Model") then
                                local eid = getResourceID(item)
                                local ppart = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
                                if eid and ppart then
                                    -- Cache the actual required references to avoid lookups in the fast loop
                                    table.insert(resourceCache, {
                                        model = item,
                                        part = ppart,
                                        eid = eid
                                    })
                                end
                            elseif item:IsA("BasePart") then
                                -- Some resources are parts with EntityID attributes.
                                local eid = item:GetAttribute("EntityID") or item:GetAttribute("ID")
                                if not eid then
                                    for _, value in pairs(item:GetAttributes()) do
                                        if typeof(value) == "number" and value > 1000 then eid = value break end
                                    end
                                end
                                if eid then
                                    table.insert(resourceCache, { model = item, part = item, eid = eid })
                                end
                            end
                        end
                    end
                end

                local range = Settings.ResourceRange or 15
                local vel = hrp.AssemblyLinearVelocity or Vector3.zero
                local horizontalVel = Vector3.new(vel.X, 0, vel.Z)
                local tweening = (isTweening == true) or (horizontalVel.Magnitude > 18)
                local confirmRange = tweening and (range + 4) or range
                local rangeSq = confirmRange * confirmRange
                local targetCount = tonumber(Settings.ResourceTargetCount) or 1
                local targets = {}
                local hrpPos = hrp.Position

                -- Process from the pre-computed fast cache
                local newCache = {}
                for i = 1, #resourceCache do
                    local resData = resourceCache[i]
                    -- Instead of table.remove (O(N^2) lag), we rebuild the table (O(N) and highly optimized)
                    if resData.model and resData.model.Parent then
                        table.insert(newCache, resData)
                        
                        local diff = resData.part.Position - hrpPos
                        local distSq = diff:Dot(diff)
                        
                        -- Use a slightly larger detection range to prepare targets
                        if distSq <= (rangeSq + 100) then -- (range+10)^2
                            table.insert(targets, { eid = resData.eid, distSq = distSq, pos = resData.part.Position })
                        end
                    end
                end
                resourceCache = newCache

                if #targets > 0 then
                    table.sort(targets, function(a, b) return a.distSq < b.distSq end)
                    
                    local selectedTargets = {}
                    for i = 1, math.min(targetCount, #targets) do 
                        -- Final check against the actual hit range
                        if targets[i].distSq <= rangeSq then
                            table.insert(selectedTargets, { eid = targets[i].eid, pos = targets[i].pos })
                        end
                    end
                    
                    if #selectedTargets > 0 then
                        hitTargets(selectedTargets)
                    end
                end
            end)
            
            task.wait(Settings.ResourceCooldown or 0.03)
        end
        resourceActive = false
    end)
end

