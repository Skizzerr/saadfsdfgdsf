    ASTER.Tabs.Automation:AddButton("Auto Tribe Sniper", function()
         local ReplicatedStorage = game:GetService("ReplicatedStorage")
         local Players = game:GetService("Players")
         local LocalPlayer = Players.LocalPlayer
     
         -- Attempt to load real modules from the game
         local Modules = ReplicatedStorage:WaitForChild("Modules", 5)
         if not Modules then
             warn("Could not find Modules folder in ReplicatedStorage. Is the game loaded?")
             return
         end
     
         -- Safely require modules
         local success, result = pcall(function()
             return {
                 Packets = require(Modules:WaitForChild("Packets")),
                 ColorData = require(Modules:WaitForChild("ColorData")),
                 GameUtil = require(Modules:WaitForChild("GameUtil"))
             }
         end)
     
         if not success then

             return
         end
     
         local GameModules = result
         local Packets = GameModules.Packets
         local ColorData = GameModules.ColorData
         local GameUtil = GameModules.GameUtil
     
         task.spawn(function()
             while true do
                 -- 1. Check if we are already in a tribe
                 local inTribe = GameUtil.isInATribe(LocalPlayer.UserId)
                 if inTribe then

                     
                     -- Play success sound
                     local LocalSounds = ReplicatedStorage:FindFirstChild("LocalSounds")
                     if LocalSounds and LocalSounds:FindFirstChild("Quicks") and LocalSounds.Quicks:FindFirstChild("TribeSound") then
                         LocalSounds.Quicks.TribeSound:Play()
                     end
                     break -- Exit the loop
                 end
     
                 -- Get all available colors
                 local possibleColors = {}
                 for colorName, _ in pairs(ColorData.TribeColors) do
                     table.insert(possibleColors, colorName)
                 end
     
                 for _, colorName in ipairs(possibleColors) do
                     -- Check again inside the inner loop
                     if GameUtil.isInATribe(LocalPlayer.UserId) then
                          break
                     end
     
                     
                     -- Send manual packet
                     if ByteNetReliable then
                         local tribeID = packetData().packets.CreateTribe
                         if tribeID then
                             local len = #colorName
                             local b = buffer.create(4 + len)
                             buffer.writeu8(b, 0, 0)
                             buffer.writeu8(b, 1, tribeID)
                             buffer.writeu16(b, 2, len)
                             buffer.writestring(b, 4, colorName)
                             ByteNetReliable:FireServer(b)
                             
                             task.wait(0.05)
                         end
                     end
                 end
                 
                 task.wait(0.02) -- Wait before retrying the whole list if still not in a tribe
             end
         end)
    end)
end

