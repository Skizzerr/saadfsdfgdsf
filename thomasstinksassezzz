                                if isActive then 
                                    local eID = getHiddenID(v) 
                                    if eID and ByteNetReliable and bottleID then 
                                        -- Fire the SweepPotion packet (ID 196) with Bottle ID
                                        local b = buffer.create(8)
                                        buffer.writeu8(b, 0, 0)
                                        buffer.writeu8(b, 1, packetData().packets.SweepPotion)       -- Action ID 196
