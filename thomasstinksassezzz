                    cameraPitch = cameraPitch - math.rad(delta.Y * rotationSpeed * 3)
                    cameraPitch = math.clamp(cameraPitch, -math.pi/2 + 0.01, math.pi/2 - 0.01)

                    camera.CFrame = CFrame.new(camera.CFrame.Position) * CFrame.fromEulerAnglesYXZ(cameraPitch, cameraYaw, 0)
                    lastRotationPos = input.Position
                end
            end)

            phoneInputEndedConn = UserInputService.InputEnded:Connect(function(input)
                if input == rotationInput then
                    rotationInput = nil
                end
            end)



        else
            -- Disable FreeCam
            if hrp and Settings.OriginalHRPAnchored ~= nil then
