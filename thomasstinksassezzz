local meteorEspConnection = nil
local meteorHighlights = {}

function startMeteorESP()
    if meteorEspConnection and meteorEspConnection.Connected then return end

    meteorEspConnection = runs.RenderStepped:Connect(function()
        local masterEnabled = Settings.MeteorCoreESPEnabled

        if not masterEnabled then
            if meteorEspConnection then
                meteorEspConnection:Disconnect()
                meteorEspConnection = nil
            end
            for model, highlightStuff in pairs(meteorHighlights) do
                if highlightStuff.highlight then highlightStuff.highlight:Destroy() end
                if highlightStuff.billboard then highlightStuff.billboard:Destroy() end
            end
            meteorHighlights = {}
            return
        end

        local currentMeteors = {}
        local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
        
        -- List of meteors to track
        local meteorTargets = {
            workspace:FindFirstChild("Meteor Core"),
            workspace:FindFirstChild("Crystal Meteor Core")
        }

        for _, meteor in ipairs(meteorTargets) do
            if meteor and meteor:IsA("Model") and meteor.PrimaryPart then
                currentMeteors[meteor] = true
                if not meteorHighlights[meteor] then
                    -- Create new ESP
                    local color = Settings.ESPColors.PlayerESP or Color3.new(1,1,1)
                    local highlight = Instance.new("Highlight")
                    highlight.Name = "ESP_Highlight"
                    highlight.FillColor = color
                    highlight.OutlineColor = color
                    highlight.FillTransparency = 0.5
                    highlight.OutlineTransparency = 0
