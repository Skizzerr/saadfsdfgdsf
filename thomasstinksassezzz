function startMultiplyPlantBox()
    if placeGridActive then return end
    placeGridActive = true
    table.clear(pendingPlacements) -- Reset state
    
    task.spawn(function()
        while Settings.MultiplyPlantBox or Settings.SoloPatternPlantBoxes do
            local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then task.wait(0.02) continue end
            
            -- Retry Logic: Cleanup pending placements after 1.5 seconds to retry failed spots
            local now = tick()
            for key, time in pairs(pendingPlacements) do 
                if now - time > 1.5 then pendingPlacements[key] = nil end 
            end

            -- Grid Constants (Must match updatePreview)
            local Z_GAP = 5.24
            local X_GAP = 6.05
            local OFFSET = 3.025
            
            -- Determine Center
            local centerPos = hrp.Position
            -- Follow Aim removed as requested
            
            local baseRow = math.floor(centerPos.Z / Z_GAP + 0.5)
            local baseCol = math.floor(centerPos.X / X_GAP + 0.5)
            
            local RADIUS = 6
            if Settings.SoloPatternPlantBoxes and not Settings.MultiplyPlantBox then
                RADIUS = 0 
            end

            local candidates = {}
            
            for r = baseRow - RADIUS, baseRow + RADIUS do
                for c = baseCol - RADIUS, baseCol + RADIUS do
                    local rowDiff = r 
                    local currentOffset = (math.abs(rowDiff) % 2 == 1) and OFFSET or 0
                    local targetX = (c * X_GAP) + currentOffset
                    local targetZ = (r * Z_GAP)
                    
                    -- Distance Check (Square for Multi, Exact for Solo)
                    local isValid = true
                    if RADIUS == 0 then
                        isValid = (r == baseRow and c == baseCol)
                    end
                    
                    if isValid then
                         -- Check Occupancy (Strict Model Center Check)
                         local checkCFrame = CFrame.new(targetX, hrp.Position.Y, targetZ)
                         local checkSize = Vector3.new(4, 10, 4) 
                         local parts = workspace:GetPartBoundsInBox(checkCFrame, checkSize)
                         local occupied = false
                         
                         for _, p in ipairs(parts) do 
                             local model = p:FindFirstAncestorOfClass("Model")
                             if model and model.Name == "Plant Box" then
                                  local pPos = model:GetPivot().Position
                                  local distToCenter = math.sqrt((pPos.X - targetX)^2 + (pPos.Z - targetZ)^2)
                                  if distToCenter < 2.0 then
                                     occupied = true 
                                     break 
                                  end
                             end 
                         end
                         
                         if not occupied then
                             local key = string.format("%.1f,%.1f", targetX, targetZ)
                             if not pendingPlacements[key] then
                                 table.insert(candidates, {x = targetX, z = targetZ, key = key})
                             end
                         end
                    end
                end
            end
            
            -- Sort candidates: Row-Major (Top-to-Bottom, Left-to-Right)
            table.sort(candidates, function(a, b) 
                if math.abs(a.z - b.z) > 0.1 then
                    return a.z < b.z 
                end
                return a.x < b.x 
            end)
            
            local placedCount = 0
            for _, cand in ipairs(candidates) do
                if placedCount >= 1 then break end
                
                -- Raycast to find ground height
                local rayOrigin = Vector3.new(cand.x, hrp.Position.Y + 30, cand.z)
                local rayDir = Vector3.new(0, -500, 0)
                local rayParams = RaycastParams.new()
                
                local ignoreList = {plr.Character, PreviewContainer, DockPreviewContainer}
                local ignoreFolders = {"Resources", "Rubble", "Critters", "Items", "Players", "MeteorParts"}
                for _, name in ipairs(ignoreFolders) do
                    local f = workspace:FindFirstChild(name)
                    if f then table.insert(ignoreList, f) end
                end
                
                rayParams.FilterDescendantsInstances = ignoreList
                rayParams.FilterType = Enum.RaycastFilterType.Exclude
                rayParams.IgnoreWater = true
                
                local hit = workspace:Raycast(rayOrigin, rayDir, rayParams)
                if hit then
                    local validSurface = false
                    if hit.Instance:IsA("Terrain") then
                        validSurface = true
                    else
                        local model = hit.Instance:FindFirstAncestorOfClass("Model")
                        if model and model.Parent and model.Parent.Name == "Deployables" then
                            validSurface = true
                        end
                    end

                    if validSurface then
                        local targetY = hit.Position.Y
                        local pos = Vector3.new(cand.x, targetY, cand.z)
                        local name = "Plant Box"
                        
                        if ByteNetReliable then
                            local nameLen = #name
                            local b = buffer.create(4 + nameLen + 24)
                            buffer.writeu8(b, 0, 0)
                            buffer.writeu8(b, 1, packetData().packets.PlaceStructure)
                            buffer.writeu16(b, 2, nameLen)
                            for i = 1, nameLen do buffer.writeu8(b, 3 + i, string.byte(name, i)) end
                            
                            local offset = 4 + nameLen
                            buffer.writef32(b, offset, pos.X)
                            buffer.writef32(b, offset + 4, pos.Y)
                            buffer.writef32(b, offset + 8, pos.Z)
                            buffer.writef32(b, offset + 12, 0) -- RotX
                            buffer.writef32(b, offset + 16, 0) -- RotY
                            buffer.writef32(b, offset + 20, 0) -- RotZ
                            
                            ByteNetReliable:FireServer(b)
                            
                            pendingPlacements[cand.key] = tick()
                            placedCount = placedCount + 1
                            
                            -- Instant visual feedback: Remove ghost ONLY if Multi mode
                            -- For Single/Solo mode, we keep the ghost until the actual part is detected by collision loop
                            if Settings.MultiplyPlantBox and PreviewCache[cand.key] then
                                PreviewCache[cand.key]:Destroy()
                                PreviewCache[cand.key] = nil
                            end
                        end
                    end
                end
            end
            
            local delayTime = 0.4
            if Settings.SoloPatternPlantBoxes and not Settings.MultiplyPlantBox then
                delayTime = 0.05
            end
            task.wait(delayTime)
        end
        placeGridActive = false
    end)
end

