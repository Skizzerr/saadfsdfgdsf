        target = godTarget or normalTarget

        if not target then return end
        
        local targetChar = target.Character
        local targetHrp = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
        if not targetHrp then return end

        -- Calculate position based on movement (Velocity) or facing direction (LookVector)
        local velocity = targetHrp.AssemblyLinearVelocity
        local moveVec = Vector3.new(velocity.X, 0, velocity.Z)
        
        local targetPos
        
        if moveVec.Magnitude > 2 then
            -- Moving: Place ahead of movement (prediction)
            targetPos = targetHrp.Position + (moveVec.Unit * 10) 
        else
            -- Stationary: Place in front of face
            local lookVec = targetHrp.CFrame.LookVector
            lookVec = Vector3.new(lookVec.X, 0, lookVec.Z)
            
            if lookVec.Magnitude > 0.01 then
                lookVec = lookVec.Unit
            else
                lookVec = Vector3.new(1, 0, 0)
            end
            targetPos = targetHrp.Position + (lookVec * 8)
        end
        local groundPos = GetGroundPosition(targetPos, targetChar)
        
        if groundPos then
            -- Use strict Identity rotation (No rotation) to prevent tipping/tilting
            -- User requested: "always be up right" and "not change rotation like sideways"
            local placeCFrame = CFrame.new(groundPos) 
            placeHutAt(placeCFrame)
        end
    end

    AttemptVoodooNearest = function()
        local target = nil
        local minDistance = 100 -- Max range
        local myChar = plr.Character
        local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
        
        local godTarget = nil
        local godDist = 100
        local normalTarget = nil
        local normalDist = 100
        
        if myHrp then
            for _, player in pairs(game:GetService("Players"):GetPlayers()) do
                if player ~= plr then
                     local isTargetable = true
                     
                     -- Check Teams
                     local myTeam = plr.Team
                     local noTribe = game:GetService("Teams"):FindFirstChild("NoTribe")
                     
                     if myTeam ~= noTribe and player.Team == myTeam then
                         isTargetable = false
                     end

                     if isTargetable and isAlly(player) then
                         isTargetable = false
                     end
                     
                     if isTargetable and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        local hrp = player.Character.HumanoidRootPart
                    local dist = (hrp.Position - myHrp.Position).Magnitude
                    
                    if dist < 100 then
                        -- Check for God Item
                        local isGod = false
                        if hasGodItem then
                            if hasGodItem(player) then isGod = true end
                        else
                            -- Fallback
                            for _, part in ipairs(player.Character:GetChildren()) do
                                if part.Name:find("God") then isGod = true break end
                            end
                        end

                        if isGod then
                            if dist < godDist then
                                godDist = dist
                                godTarget = player
                            end
                        end
                        
                        if dist < normalDist then
                            normalDist = dist
                            normalTarget = player
                        end
                    end
                end
            end
        end
        end
        
        target = godTarget or normalTarget
        
        if not target then return end
        
        local targetChar = target.Character
        local targetHrp = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
        if not targetHrp then return end

        sendVoodooPacket(targetHrp.Position)
    end

