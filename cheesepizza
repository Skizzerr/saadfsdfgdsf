    destroyDisc(); sg:Destroy()
end)

UIS.InputBegan:Connect(function(inp, gpe)
    if inp.KeyCode == Enum.KeyCode.RightShift then
        guiOpen  = not guiOpen
        mf.Visible = guiOpen
        if not guiOpen then destroyDisc()
        elseif showArea then buildDisc(); refreshDisc() end
    end
end)

-- Auto-refresh every 0.8 s
local lastAutoCount = 0
RunService.Heartbeat:Connect(function()
    local now = tick()
    if now - lastAutoCount >= 0.8 then
        lastAutoCount = now
        countCoins()
    end
end)

