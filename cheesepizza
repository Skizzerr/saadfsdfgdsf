--  DRAG LOGIC
-- ════════════════════════════════════════════════════════════════════════════
local dragging, dragInput, dragStart, startPos

tb.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging  = true
        dragStart = inp.Position
        startPos  = mf.Position
        inp.Changed:Connect(function()
            if inp.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
tb.InputChanged:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseMovement then dragInput = inp end
end)
UIS.InputChanged:Connect(function(inp)
    if inp == dragInput and dragging then
        local d = inp.Position - dragStart
        mf.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X,
                                 startPos.Y.Scale, startPos.Y.Offset + d.Y)
    end
end)

-- ════════════════════════════════════════════════════════════════════════════
--  AREA DISC
-- ════════════════════════════════════════════════════════════════════════════
local function destroyDisc()
    if areaDisc then areaDisc:Destroy(); areaDisc = nil end
end

local function buildDisc()
    destroyDisc()
    areaDisc               = Instance.new("Part")
    areaDisc.Name          = "CoinAreaRing"
    areaDisc.Shape         = Enum.PartType.Cylinder
    areaDisc.Anchored      = true
    areaDisc.CanCollide    = false
    areaDisc.CastShadow    = false
    areaDisc.Material      = Enum.Material.Neon
    areaDisc.Color         = Color3.fromRGB(255, 200, 0)
    areaDisc.Transparency  = 0.55
    areaDisc.Parent        = workspace
end

local function refreshDisc()
    if not showArea then return end
    if not areaDisc then buildDisc() end
    local r = currentRadius == math.huge and 9999 or currentRadius
    areaDisc.Size  = Vector3.new(0.15, r * 2, r * 2)
    areaDisc.CFrame = CFrame.new(rootPart.Position.X, rootPart.Position.Y - 2.8, rootPart.Position.Z)
                      * CFrame.Angles(0, 0, math.pi / 2)
end

RunService.RenderStepped:Connect(function()
    if showArea and areaDisc and rootPart then
        areaDisc.CFrame = CFrame.new(rootPart.Position.X, rootPart.Position.Y - 2.8, rootPart.Position.Z)
                          * CFrame.Angles(0, 0, math.pi / 2)
    end
end)

-- ════════════════════════════════════════════════════════════════════════════
--  SLIDER LOGIC
-- ════════════════════════════════════════════════════════════════════════════
local function applyAlpha(a)
    a = math.clamp(a, 0, 1)
    sliderFill.Size     = UDim2.new(a, 0, 1, 0)
    knob.Position       = UDim2.new(a, -6, 0.5, -6)
    if a >= 0.99 then
        currentRadius   = math.huge
        radLbl.Text     = "Radius:  ∞  studs"
    else
        currentRadius   = math.max(1, math.floor(a * MAX_STUDS))
        radLbl.Text     = "Radius:  " .. currentRadius .. "  studs"
    end
    refreshDisc()
    if countCoins then countCoins() end
end

local slidingActive = false

sliderTrack.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        slidingActive = true
        local a = math.clamp((inp.Position.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
        applyAlpha(a)
    end
end)
UIS.InputChanged:Connect(function(inp)
    if slidingActive and inp.UserInputType == Enum.UserInputType.MouseMovement then
        local a = math.clamp((inp.Position.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
        applyAlpha(a)
    end
end)
UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then slidingActive = false end
end)

-- ════════════════════════════════════════════════════════════════════════════
--  AREA TOGGLE
-- ════════════════════════════════════════════════════════════════════════════
togBg.MouseButton1Click:Connect(function()
    showArea = not showArea
    if showArea then
        TweenService:Create(togBg,   TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(210, 165, 28)}):Play()
        TweenService:Create(togKnob, TweenInfo.new(0.12), {Position = UDim2.new(1, -12, 0.5, -5),
                                                             BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
        buildDisc(); refreshDisc()
        if countCoins then countCoins() end
    else
        TweenService:Create(togBg,   TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(45, 44, 62)}):Play()
        TweenService:Create(togKnob, TweenInfo.new(0.12), {Position = UDim2.new(0, 2, 0.5, -5),
                                                             BackgroundColor3 = Color3.fromRGB(100, 100, 120)}):Play()
        destroyDisc()
        if countCoins then countCoins() end
    end
end)

-- ════════════════════════════════════════════════════════════════════════════
--  COUNT COINS
-- ════════════════════════════════════════════════════════════════════════════
countCoins = function()
    local items = workspace:FindFirstChild("Items")
    if not items then
        coinVal.Text  = "ERR"
        partsLbl.Text = "workspace.Items not found"
        return
    end
    local parts = 0
    for _, obj in ipairs(items:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "Coin2" then
            if currentRadius == math.huge then
                parts += 1
            elseif (obj.Position - rootPart.Position).Magnitude <= currentRadius then
                parts += 1
            end
        end
    end
    local total = parts * COIN_VALUE
    coinVal.Text  = tostring(total)
    partsLbl.Text = parts .. " part" .. (parts ~= 1 and "s" or "") .. "  ×5  =  " .. total
    print(("[CoinCounter] %d parts → %d coins"):format(parts, total))
end

countBtn.MouseButton1Click:Connect(countCoins)
countBtn.MouseEnter:Connect(function()
    TweenService:Create(countBtn, TweenInfo.new(0.08), {BackgroundColor3 = Color3.fromRGB(245, 195, 50)}):Play()
end)
countBtn.MouseLeave:Connect(function()
    TweenService:Create(countBtn, TweenInfo.new(0.08), {BackgroundColor3 = Color3.fromRGB(210, 165, 28)}):Play()
end)

